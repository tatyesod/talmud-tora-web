<%- include('../partials/header', {title: classRow.name, wide: true}) %>

<div class="card class-sticky-top">
  <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:10px;">
    <h1>כיתה: <%= classRow.name %><%= classRow.parallel ? ' ('+classRow.parallel+')' : '' %></h1>
    <div class="actions">
      <a href="/classes/<%= classRow.id %>/edit" class="btn">עריכה</a>
      <form method="POST" action="/classes/<%= classRow.id %>?_method=DELETE" onsubmit="return confirm('האם למחוק את הכיתה?');" style="display:inline">
        <button type="submit" class="btn danger">מחיקה</button>
      </form>
      <a href="/classes" class="btn secondary">חזרה לכיתות</a>
    </div>
  </div>
  <table>
    <tr><th>סניף</th><td><%= classRow.branch || '' %></td><th>קטגוריית שכר לימוד</th><td><%= classRow.category_name || '' %></td></tr>
    <tr><th>מחיר</th><td><%= classRow.price != null ? classRow.price+' ₪' : '' %></td><th>סטטוס</th><td><%= classRow.status || '' %></td></tr>
    <tr><th>סמל מוסד</th><td colspan="3"><%= classRow.institution_code || '—' %></td></tr>
  </table>
</div>

<div class="card">
  <h3>פילוח מגזרים בכיתה (תלמידים פעילים)</h3>
  <% if (sectorBreakdown.length === 0) { %>
    <p class="empty-state">אין נתונים</p>
  <% } else { %>
    <table>
      <thead><tr><th>מגזר</th><th>מס' תלמידים</th></tr></thead>
      <tbody>
        <% sectorBreakdown.forEach(s => { %>
          <tr><td><%= s.sector %></td><td><%= s.count %></td></tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card">
  <h3>מלמדים בכיתה זו</h3>
  <% if (teachers.length === 0) { %>
    <p class="empty-state">לא משובץ מלמד</p>
  <% } else { %>
    <table>
      <thead><tr><th>תפקיד</th><th>שם</th><th>נייד</th></tr></thead>
      <tbody>
        <% teachers.forEach(t => { %>
          <tr><td><%= t.role || '' %></td><td><a href="/teachers/<%= t.id %>"><%= t.first_name %> <%= t.last_name %></a></td><td><%- phoneLink(t.mobile) %></td></tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card">
  <h3>תלמידים בכיתה</h3>
  <% if (students.length === 0) { %>
    <p class="empty-state">אין תלמידים בכיתה זו</p>
  <% } else { %>
    <div class="table-scroll-wrap">
    <table>
      <thead><tr>
        <th><a href="<%= sortUrl('last_name') %>">שם משפחה<%= sortIndicator('last_name') %></a></th>
        <th><a href="<%= sortUrl('nickname') %>">שם כינוי<%= sortIndicator('nickname') %></a></th>
        <th><a href="<%= sortUrl('address') %>">כתובת<%= sortIndicator('address') %></a></th>
        <th><a href="<%= sortUrl('birth_date') %>">תאריך לידה עברי<%= sortIndicator('birth_date') %></a></th>
        <th><a href="<%= sortUrl('birth_date') %>">תאריך לידה לועזי<%= sortIndicator('birth_date') %></a></th>
        <th><a href="<%= sortUrl('sector') %>">מגזר<%= sortIndicator('sector') %></a></th>
        <th><a href="<%= sortUrl('home_phone') %>">טלפון ראשי<%= sortIndicator('home_phone') %></a></th>
        <th><a href="<%= sortUrl('father_mobile') %>">טלפון אב<%= sortIndicator('father_mobile') %></a></th>
        <th><a href="<%= sortUrl('mother_mobile') %>">טלפון אם<%= sortIndicator('mother_mobile') %></a></th>
        <th><a href="<%= sortUrl('status') %>">סטטוס<%= sortIndicator('status') %></a></th>
        <th></th>
      </tr></thead>
      <tbody>
        <% students.forEach(s => {
          const address = [s.street, s.house_number].filter(Boolean).join(' ') + (s.city ? (', ' + s.city) : '');
        %>
          <tr>
            <td><%= s.last_name || '' %></td>
            <td><%= s.nickname || s.first_name || '' %></td>
            <td class="nowrap-cell"><%= address.trim().replace(/^,\s*/, '') || '' %></td>
            <td class="nowrap-cell"><%= s.birth_date_hebrew_str || '' %></td>
            <td class="nowrap-cell"><%= s.birth_date_civil_str || '' %></td>
            <td><%= s.sector || '' %></td>
            <td><%- phoneLink(s.home_phone) %></td>
            <td><%- phoneLink(s.father_mobile) %></td>
            <td><%- phoneLink(s.mother_mobile) %></td>
            <td><span class="badge <%= s.status !== 'פעיל' ? 'archive' : '' %>"><%= s.status || '' %></span></td>
            <td><a href="/students/<%= s.id %>" class="btn small secondary">צפייה</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
    <p style="color:var(--muted); margin-top:10px;">סה"כ <%= students.length %> תלמידים</p>
  <% } %>
</div>

<style>
.class-sticky-top {
  position: sticky;
  top: 66px;
  z-index: 15;
  background: var(--card-bg);
}
</style>

<%- include('../partials/footer') %>
