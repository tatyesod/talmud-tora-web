<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>הזמנה - <%= supplier.name %></title>
  <style>
    @page { size: A4; margin: 14mm 16mm; }
    * { box-sizing: border-box; }
    body { font-family: "Segoe UI", "Arial Hebrew", Arial, sans-serif; direction: rtl; margin: 0; color: #1a1a1a; font-size: 14px; }
    .page { max-width: 820px; margin: 0 auto; padding: 10px 28px; }

    .form-header {
      display: flex; justify-content: space-between; align-items: flex-start;
      border-bottom: 3px solid #2c5f7c; padding-bottom: 8px; margin-bottom: 10px;
    }
    .form-header img { height: 60px; }
    .form-header .school-info { text-align: left; font-size: 0.8em; color: #555; line-height: 1.4; }
    .bsd { text-align: left; font-size: 0.8em; color: #888; margin-bottom: 8px; }

    h2.title { text-align: center; margin: 6px 0; font-size: 1.4em; text-decoration: underline; }

    table.meta { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 0.92em; }
    table.meta td { padding: 4px 8px; }
    table.meta td.label { color: #555; white-space: nowrap; }
    table.meta td.value { border-bottom: 1px solid #888; font-weight: 600; }

    table.items { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 0.92em; }
    table.items th { background: #2c5f7c; color: #fff; padding: 8px; text-align: right; }
    table.items td { padding: 7px 8px; border-bottom: 1px solid #ddd; }
    table.items tr:nth-child(even) { background: #f7f9fb; }
    .total-row td { font-weight: 700; border-top: 2px solid #2c5f7c; background: #eef4f8; }

    .no-print { }
    @media print { .no-print { display: none !important; } }
  </style>
</head>
<body onload="window.print()">
  <div class="page">
    <div class="form-header">
      <img src="/images/logo-reports.jpg" alt="לוגו" />
      <div class="school-info">
        תלמוד תורה החדש (יסוד העולם)<br />
        כתובת: סוקולוב 5, בני ברק<br />
        טל: 03-6185020 | פקס: 03-6185030
      </div>
    </div>
    <div class="bsd">בס"ד</div>

    <h2 class="title">הזמנה מספק</h2>

    <table class="meta">
      <tr><td class="label">ספק:</td><td class="value"><%= supplier.name %></td><td class="label">תאריך:</td><td class="value"><%= today %></td></tr>
      <tr><td class="label">סניף מזמין:</td><td class="value"><%= branch || '' %></td>
          <td class="label">איש קשר אצל הספק:</td><td class="value"><%= contact ? contact.contact_name + (contact.phone ? ' - '+contact.phone : '') : '' %></td></tr>
    </table>

    <table class="items">
      <thead><tr><th>מוצר</th><th>קטגוריה</th><th>הערות</th><th>כמות להזמנה</th></tr></thead>
      <tbody>
        <% let totalQty = 0; %>
        <% rows.forEach(r => { totalQty += r.to_order; %>
          <tr>
            <td><%= r.item_name %></td>
            <td><%= r.category || '' %></td>
            <td><%= r.notes || '' %></td>
            <td><strong><%= r.to_order %></strong></td>
          </tr>
        <% }) %>
        <tr class="total-row"><td colspan="3">סה"כ יחידות</td><td><%= totalQty %></td></tr>
      </tbody>
    </table>
  </div>

  <div class="no-print" style="text-align:center; margin-top:20px;">
    <button onclick="window.print()">🖨️ הדפסה</button>
  </div>
</body>
</html>
