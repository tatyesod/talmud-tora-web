<%- include('../partials/header', {title: mode === 'new' ? 'הנחה חדשה' : 'עריכת הנחה'}) %>

<div class="card">
  <h1><%= mode === 'new' ? 'הוספת הנחה' : 'עריכת הנחה' %></h1>
  <form method="POST" action="<%= mode === 'new' ? '/tuition/discounts' : '/tuition/discounts/' + discount.id + '?_method=PUT' %>">
    <div class="form-grid">
      <div class="form-group">
        <label>מספר ילדים פעילים (סף להחלת ההנחה)</label>
        <input type="number" name="siblings_count" value="<%= discount.siblings_count != null ? discount.siblings_count : '' %>" required />
      </div>
      <div class="form-group">
        <label>סוג הנחה</label>
        <select name="discount_type_id">
          <option value="">--</option>
          <% discountTypes.forEach(t => { %>
            <option value="<%= t.id %>" <%= String(discount.discount_type_id) === String(t.id) ? 'selected' : '' %>><%= t.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>תיאור סוג ההנחה (לתצוגה, למשל "אחוזים")</label>
        <input type="text" name="discount_type_name" value="<%= discount.discount_type_name || '' %>" />
      </div>
      <div class="form-group">
        <label>אחוז הנחה (%)</label>
        <input type="number" step="0.01" name="amount" value="<%= discount.amount != null ? discount.amount : '' %>" required />
      </div>
    </div>
    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">שמירה</button>
      <a href="/tuition" class="btn secondary">ביטול</a>
    </div>
  </form>
  <% if (mode === 'edit') { %>
    <form method="POST" action="/tuition/discounts/<%= discount.id %>?_method=DELETE" onsubmit="return confirm('האם למחוק את ההנחה?');" style="margin-top:10px;">
      <button type="submit" class="btn danger">מחיקת הנחה</button>
    </form>
  <% } %>
</div>

<%- include('../partials/footer') %>
