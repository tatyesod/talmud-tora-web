<%- include('../partials/header', {title: mode === 'new' ? 'קטגוריה חדשה' : 'עריכת קטגוריה'}) %>

<div class="card">
  <h1><%= mode === 'new' ? 'הוספת קטגוריית שכר לימוד' : 'עריכת קטגוריה' %></h1>
  <form method="POST" action="<%= mode === 'new' ? '/tuition/categories' : '/tuition/categories/' + category.id + '?_method=PUT' %>">
    <div class="form-grid">
      <div class="form-group"><label>שם הקטגוריה</label><input type="text" name="name" value="<%= category.name || '' %>" required /></div>
      <div class="form-group"><label>מחיר חודשי (₪)</label><input type="number" step="0.01" name="price" value="<%= category.price != null ? category.price : '' %>" /></div>
      <div class="form-group full">
        <label>כיתות בקטגוריה זו (ניתן לבחור כמה - Ctrl+לחיצה)</label>
        <select name="class_ids" multiple size="10" style="height:220px;">
          <% allClasses.forEach(c => { %>
            <option value="<%= c.id %>" <%= selectedClassIds.includes(c.id) ? 'selected' : '' %>>
              <%= c.name %><%= c.parallel ? ' ('+c.parallel+')' : '' %><%= (c.category_id && !selectedClassIds.includes(c.id)) ? ' — כרגע בקטגוריה אחרת' : '' %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">שמירה</button>
      <a href="/tuition" class="btn secondary">ביטול</a>
    </div>
  </form>
  <% if (mode === 'edit') { %>
    <form method="POST" action="/tuition/categories/<%= category.id %>?_method=DELETE" onsubmit="return confirm('האם למחוק את הקטגוריה?');" style="margin-top:10px;">
      <button type="submit" class="btn danger">מחיקת קטגוריה</button>
    </form>
  <% } %>
</div>

<%- include('../partials/footer') %>
