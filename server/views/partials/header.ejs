<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'תלמוד תורה' %></title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/images/icon-192.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0d1b2e" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="ת&quot;ת החדש" />
  <link rel="stylesheet" href="/css/style.css?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '' %>" />
  <script src="/js/auto-filter.js" defer></script>
  <script src="/js/phone-link.js" defer></script>
  <script src="/js/presence.js" defer></script>
</head>
<body>
  <header class="topbar">
    <div class="brand"><a href="/" style="color:#fff; display:flex; align-items:center; gap:10px;"><img src="/images/logo.png" alt="לוגו" style="height:40px; width:auto;" /> תלמוד תורה החדש</a></div>
    <nav>
      <a href="/">בית</a>
      <a href="/students">תלמידים</a>
      <a href="/classes">כיתות ומחזורים</a>
      <a href="/teachers">מלמדים</a>
      <a href="/families">משפחות</a>
      <a href="/tuition">שכר לימוד</a>
      <a href="/suppliers">ספקים</a>
      <a href="/expenses">הוצאות</a>
      <a href="/events">אירועים</a>
      <a href="/inventory">מלאי ותחזוקה</a>
      <a href="/parent-comm">תקשורת הורים</a>
      <a href="/books">הזמנת ספרים</a>
      <a href="/reports">דוחות</a>
      <a href="/year">ניהול שנה</a>
      <a href="/messages">הודעות</a>
      <% if (isAdmin) { %><a href="/users">משתמשים</a><% } %>
      <a href="/profile">הפרופיל שלי</a>
      <% if (user) { %>
        <a href="/profile" style="margin-inline-start:16px; font-size:0.9em; color:var(--text);">👤 <%= user %></a>
        <form action="/logout" method="POST" style="display:inline">
          <button type="submit" class="btn small secondary" style="margin-inline-start:8px;">יציאה</button>
        </form>
      <% } %>
    </nav>
  </header>
  <div class="container <%= typeof wide !== 'undefined' && wide ? 'container-wide' : '' %>">
