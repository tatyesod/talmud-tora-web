<%- include('../partials/header', {title: 'הדפסת מדבקות'}) %>

<div class="card">
  <h1>🏷️ הדפסת מדבקות</h1>

  <form method="GET" action="/labels/print" target="_blank">
    <div class="form-grid">

      <div class="form-group">
        <label>סוג דף מדבקות (TANEX)</label>
        <select name="format" required>
          <% Object.entries(formats).forEach(([key, f]) => { %>
            <option value="<%= key %>"><%= f.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>תוכן המדבקה</label>
        <select name="content_type" required>
          <option value="families">משפחות (שם + כתובת)</option>
          <option value="students">תלמידים (שם + כיתה)</option>
          <option value="teachers">מלמדים</option>
        </select>
      </div>

      <div class="form-group">
        <label>כיתה (ריק = כולם)</label>
        <select name="class_id">
          <option value="">כל הכיתות</option>
          <% classes.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %><%= c.parallel ? ' ' + c.parallel : '' %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>כמות עותקים לכל רשומה</label>
        <select name="copies">
          <option value="1" selected>1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
        </select>
      </div>

    </div>

    <div style="background:#f0f4f8; border-radius:10px; padding:14px; margin:14px 0; font-size:0.88em;">
      <strong>פירוט הפורמטים:</strong>
      <table style="width:100%; margin-top:8px; border-collapse:collapse;">
        <thead><tr style="background:#e0e8f0;"><th style="padding:5px 8px; text-align:right;">פורמט</th><th style="padding:5px 8px;">בדף</th><th style="padding:5px 8px;">מידות מדבקה</th><th style="padding:5px 8px;">שימוש מומלץ</th></tr></thead>
        <tbody>
          <tr><td style="padding:5px 8px; font-weight:700;">TANEX 2133</td><td style="padding:5px 8px; text-align:center;">33 (3×11)</td><td style="padding:5px 8px; text-align:center;">70 × 25.4 מ"מ</td><td style="padding:5px 8px;">משפחות, רחב</td></tr>
          <tr style="background:#f8f9fa;"><td style="padding:5px 8px; font-weight:700;">TANEX 2072</td><td style="padding:5px 8px; text-align:center;">72 (6×12)</td><td style="padding:5px 8px; text-align:center;">46 × 21.2 מ"מ</td><td style="padding:5px 8px;">תלמידים</td></tr>
          <tr><td style="padding:5px 8px; font-weight:700;">TANEX 2120</td><td style="padding:5px 8px; text-align:center;">120 (6×20)</td><td style="padding:5px 8px; text-align:center;">38 × 13 מ"מ</td><td style="padding:5px 8px;">כמות גדולה</td></tr>
        </tbody>
      </table>
    </div>

    <div class="actions">
      <button type="submit" class="btn">🖨️ הפק מדבקות</button>
      <a href="/reports" class="btn secondary">חזרה לדוחות</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
