<%- include('../partials/header', {title: request.subject}) %>

<div class="card">
  <h1><%= request.subject %> <span class="badge <%= request.status !== 'סגור' ? '' : 'archive' %>"><%= request.status %></span></h1>
  <a href="javascript:history.back()" class="btn secondary" style="margin-bottom:14px; display:inline-block;">חזרה לרשימה</a>

  <table>
    <tr><th>משפחה</th><td><%= request.family_last_name || '' %></td></tr>
    <tr><th>מייל אב</th><td><%- emailLink(request.father_email) %></td></tr>
    <tr><th>מייל אם</th><td><%- emailLink(request.mother_email) %></td></tr>
    <tr><th>תוכן הפנייה</th><td><%= request.body %></td></tr>
  </table>
</div>

<div class="card">
  <h3>טיפול ומענה</h3>
  <form method="POST" action="/parent-comm/requests/<%= request.id %>?_method=PUT">
    <div class="form-grid">
      <div class="form-group">
        <label>סטטוס</label>
        <select name="status">
          <option value="פתוח" <%= request.status === 'פתוח' ? 'selected' : '' %>>פתוח</option>
          <option value="בטיפול" <%= request.status === 'בטיפול' ? 'selected' : '' %>>בטיפול</option>
          <option value="סגור" <%= request.status === 'סגור' ? 'selected' : '' %>>סגור</option>
        </select>
      </div>
      <div class="form-group full"><label>תגובה/מענה</label><textarea name="response"><%= request.response || '' %></textarea></div>
    </div>
    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">עדכון</button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
