<%- include('../partials/header', {title: 'רישום פנייה חדשה'}) %>

<div class="card">
  <h1>רישום פניית הורה חדשה</h1>
  <form method="POST" action="/parent-comm/requests">
    <div class="form-grid">
      <div class="form-group">
        <label>משפחה</label>
        <select name="family_id">
          <option value="">--</option>
          <% families.forEach(f => { %>
            <option value="<%= f.id %>"><%= f.last_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group"><label>נושא</label><input type="text" name="subject" required /></div>
      <div class="form-group full"><label>תוכן הפנייה</label><textarea name="body" required></textarea></div>
    </div>
    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">שמירה</button>
      <a href="/parent-comm/requests" class="btn secondary">ביטול</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
