<%- include('../partials/header', {title: 'מכתבי שיבוץ', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>מכתבי שיבוץ</h1>
    <div style="display:flex; gap:10px;">
      <a href="/letters/templates" class="btn secondary">📝 ניהול תבניות</a>
      <a href="/letters/generate-all/docx" class="btn">📄 הפקת מכתבים לכל הכיתות (Word אחד)</a>
    </div>
  </div>

  <p style="color:var(--muted); font-size:0.9em;">
    כל שנה: מלאו כאן את התאריך העברי ואת שנה"ל הקרובה (פעם אחת, לא לכל כיתה בנפרד), ודאו ששיבוץ המלמדים לכיתות עדכני
    (בעמוד עריכת כיתה). למטה מוצגות כל הכיתות <strong>הנוכחיות</strong> (כולל "עדיין לא נכנסו"; כיתה ח' לא מופיעה כי
    בוגריה לא ממשיכים במוסד). לכל כיתה נוכחית בוחרים <strong>תבנית מכתב</strong> (הנוסח, לפי השכבה שאליה עולים) ובנפרד
    <strong>כיתת יעד לשנה הבאה</strong> (מכיוון שלא תמיד א'1 עולה דווקא ל-ב'1). לחיצה אחת על "הפקת מכתבים לכל הכיתות"
    מייצרת קובץ Word אחד עם עמוד נפרד לכל כיתה, ממולא אוטומטית לפי הנתונים בפועל של כיתת היעד.
  </p>

  <% if (saved) { %>
    <div style="background:#e8f5e9; border:1px solid #a5d6a7; color:#2e7d32; border-radius:8px; padding:10px 16px; margin-bottom:14px;">
      ✅ ההגדרות נשמרו.
    </div>
  <% } %>

  <form method="POST" action="/letters/settings" class="form-grid" style="margin-bottom:20px;">
    <div class="form-group">
      <label>תאריך עברי למכתבים (יופיע בראש כל מכתב)</label>
      <input type="text" name="letter_hebrew_date" value="<%= settings.letter_hebrew_date %>" placeholder="לדוגמה: מנחם אב תשפ&quot;ז" />
    </div>
    <div class="form-group">
      <label>שנה"ל הקרובה (כפי שתופיע בתוך נוסח המכתב)</label>
      <input type="text" name="letter_hebrew_year" value="<%= settings.letter_hebrew_year %>" placeholder="לדוגמה: תשפ&quot;ח" />
    </div>
    <div class="form-group full"><button type="submit" class="btn small">שמירת הגדרות שנתיות</button></div>
  </form>

  <h3>שיוך כיתה נוכחית → תבנית + כיתת יעד לשנה הבאה</h3>
  <div class="table-scroll-wrap">
    <table>
      <thead><tr><th>כיתה נוכחית</th><th>סניף</th><th>תיאור מיקום/חדר (של כיתה זו)</th><th>תבנית מכתב</th><th>כיתת יעד לשנה הבאה</th><th></th></tr></thead>
      <tbody>
        <% classes.forEach(c => { %>
          <tr>
            <td class="nowrap-cell"><strong><%= c.name %><%= c.parallel ? ' '+c.parallel : '' %></strong></td>
            <td><%= c.branch || '' %></td>
            <td colspan="3">
              <form method="POST" action="/letters/class/<%= c.id %>/fields" style="display:flex; gap:8px; flex-wrap:wrap;">
                <input type="text" name="room_description" value="<%= c.room_description || '' %>"
                       placeholder="לדוגמה: בקומה 3 הכיתה האמצעית" style="flex:1; min-width:200px;" />
                <select name="letter_template_id" style="min-width:150px;">
                  <option value="">— תבנית —</option>
                  <% templates.forEach(t => { %>
                    <option value="<%= t.id %>" <%= String(c.letter_template_id) === String(t.id) ? 'selected' : '' %>><%= t.name %></option>
                  <% }) %>
                </select>
                <select name="next_year_class_id" style="min-width:170px;">
                  <option value="">— כיתת יעד —</option>
                  <% allClasses.forEach(t => { %>
                    <option value="<%= t.id %>" <%= String(c.next_year_class_id) === String(t.id) ? 'selected' : '' %>><%= t.full_name %></option>
                  <% }) %>
                </select>
                <button type="submit" class="btn small secondary">שמירה</button>
              </form>
            </td>
            <td>
              <a href="/letters/class/<%= c.id %>/preview" target="_blank" class="btn small secondary">👁️ תצוגה</a>
              <a href="/letters/class/<%= c.id %>/docx" class="btn small secondary">📄 Word</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <h3 style="margin-top:24px;">ניסיוני: מכתב לפי משפחה (כל הילדים באותו מכתב)</h3>
  <p style="color:var(--muted); font-size:0.9em;">
    כדי לנסות איך זה נראה עבור משפחה מסוימת, הזן את מזהה המשפחה (מספר ה-ID שמופיע בכתובת של כרטיס המשפחה, לדוגמה
    talmud-tora-web.onrender.com/families/<strong>42</strong>):
  </p>
  <form method="GET" action="#" onsubmit="window.open('/letters/family/'+document.getElementById('fam-id-input').value+'/preview','_blank'); return false;" style="display:flex; gap:10px; align-items:center;">
    <input type="number" id="fam-id-input" placeholder="מזהה משפחה" style="max-width:160px;" />
    <button type="submit" class="btn small secondary">👁️ תצוגה מקדימה</button>
  </form>
</div>

<%- include('../partials/footer') %>
