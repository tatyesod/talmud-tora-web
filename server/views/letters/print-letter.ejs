<%- include('../partials/header', {title: title}) %>

<div class="card" style="max-width:800px; margin:0 auto;">
  <div class="actions no-print" style="justify-content:flex-end; margin-bottom:14px;">
    <button onclick="window.print()" class="btn secondary">🖨️ הדפסה</button>
  </div>

  <div class="letter-header">
    <img src="/images/logo-reports.jpg" alt="לוגו" />
    <div class="school-info">
      תלמוד תורה החדש (יסוד העולם)<br />
      כתובת: סוקולוב 5, בני ברק<br />
      טל: 03-6185020 | פקס: 03-6185030
    </div>
  </div>
  <div class="letter-bsd">בס"ד</div>

  <div style="font-family:'Times New Roman', serif; line-height:1.4; direction:rtl;">
    <p style="font-weight:700; font-size:1.1em; margin:0 0 8px;"><%= recipientLine %></p>
    <p style="margin:0 0 10px;">שלו' וברכה,</p>

    <% if (typeof childrenRows !== 'undefined' && childrenRows) { %>
      <div style="background:#f8f5ec; border:1px solid #e0d8c0; border-radius:8px; padding:12px 16px; margin:16px 0;">
        <strong>פירוט שיבוץ הילדים במשפחה:</strong>
        <table style="margin-top:8px;">
          <thead><tr><th>שם</th><th>כיתה</th><th>סניף</th><th>מלמד</th></tr></thead>
          <tbody>
            <% childrenRows.forEach(c => { %>
              <tr>
                <td><%= c.child_name %></td>
                <td><%= c.class_full_name %></td>
                <td><%= c.branch %></td>
                <td><%= c.teacher_name %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <p style="color:var(--muted); font-size:0.85em;">⚠️ מכתב זה במצב ניסיוני: הנוסח הכללי שמופיע למטה נלקח מתבנית הילד הבכור בלבד.</p>
    <% } %>

    <% paragraphs.forEach(runs => { %>
      <p style="margin:0 0 6px;">
        <% runs.forEach(r => { %><% if (r.bold) { %><strong><%= r.text %></strong><% } else { %><%= r.text %><% } %><% }) %>
      </p>
    <% }) %>
  </div>
</div>

<style>
.letter-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 3px solid #2c5f7c;
  padding-bottom: 8px;
  margin-bottom: 6px;
}
.letter-header img { height: 60px; }
.letter-header .school-info { text-align: left; font-size: 0.8em; color: #555; line-height: 1.35; }
.letter-bsd { text-align: left; font-size: 0.8em; color: #888; margin-bottom: 10px; }

@media print {
  .no-print, header, nav, .header, .top-nav { display: none !important; }
  body { background: #fff !important; }
}
</style>

<%- include('../partials/footer') %>
