<%- include('../partials/header', {title: mode === 'new' ? 'משתמש חדש' : 'עריכת משתמש'}) %>

<div class="card">
  <h1><%= mode === 'new' ? 'הוספת משתמש חדש' : 'עריכת משתמש: ' + editUser.username %></h1>
  <% if (typeof error !== 'undefined' && error) { %><div class="error-msg"><%= error %></div><% } %>

  <form method="POST" action="<%= mode === 'new' ? '/users' : '/users/' + editUser.id + '?_method=PUT' %>">
    <div class="form-grid">
      <% if (mode === 'new') { %>
        <div class="form-group"><label>שם משתמש (לכניסה למערכת)</label><input type="text" name="username" required /></div>
      <% } %>
      <div class="form-group"><label>שם תצוגה</label><input type="text" name="display_name" value="<%= mode === 'edit' ? (editUser.display_name || '') : '' %>" /></div>
      <div class="form-group">
        <label><%= mode === 'new' ? 'סיסמה' : 'סיסמה חדשה (השאר ריק כדי לא לשנות)' %></label>
        <input type="password" name="password" <%= mode === 'new' ? 'required' : '' %> />
      </div>
      <% if (mode === 'edit') { %>
      <div class="form-group">
        <label>
          <input type="checkbox" name="force_password_change"
            <%= typeof editUser !== 'undefined' && editUser.force_password_change ? 'checked' : '' %>
            style="width:auto; margin-left:6px;" />
          חייב לשנות סיסמה בכניסה הבאה
        </label>
      </div>
      <% } %>
    </div>
    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">שמירה</button>
      <a href="/users" class="btn secondary">ביטול</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
