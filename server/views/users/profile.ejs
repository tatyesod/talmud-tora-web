<%- include('../partials/header', {title: 'הפרופיל שלי'}) %>

<div class="card">
  <h1>הפרופיל שלי</h1>
  <% if (success) { %>
    <div style="background:#eef6ee; border:1px solid #bcd9bc; border-radius:8px; padding:10px 16px; margin-bottom:14px; color:#2a5a2a;">
      ✅ הפרטים עודכנו בהצלחה!
    </div>
  <% } %>

  <form method="POST" action="/profile">
    <fieldset>
      <legend>פרטים אישיים</legend>
      <div class="form-grid">
        <div class="form-group">
          <label>שם מלא (לברכה בדף הבית)</label>
          <input type="text" name="full_name" value="<%= profileUser.full_name || '' %>" placeholder="לדוגמה: ישראל ישראלי" />
        </div>
        <div class="form-group">
          <label>שם תצוגה (מוצג בתפריט)</label>
          <input type="text" name="display_name" value="<%= profileUser.display_name || '' %>" />
        </div>
        <div class="form-group">
          <label>תפקיד</label>
          <input type="text" name="role_title" value="<%= profileUser.role_title || '' %>" placeholder="לדוגמה: מזכיר, גזבר, מנהל..." />
        </div>
        <div class="form-group">
          <label>טלפון</label>
          <input type="text" name="phone" value="<%= profileUser.phone || '' %>" />
        </div>
        <div class="form-group">
          <label>מייל</label>
          <input type="email" name="email" value="<%= profileUser.email || '' %>" />
        </div>
      </div>
    </fieldset>

    <fieldset style="margin-top:16px;">
      <legend>שינוי סיסמה (השאר ריק אם אינך רוצה לשנות)</legend>
      <div class="form-grid">
        <div class="form-group">
          <label>סיסמה חדשה</label>
          <input type="password" name="new_password" autocomplete="new-password" />
        </div>
      </div>
    </fieldset>

    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">שמירת פרטים</button>
      <a href="/" class="btn secondary">חזרה לדף הבית</a>
    </div>
  </form>
</div>

<div class="card" style="opacity:0.7;">
  <p style="color:var(--muted); font-size:0.9em;">
    שם המשתמש לכניסה: <strong><%= profileUser.username %></strong>
    <% if (profileUser.role_title) { %> · תפקיד: <strong><%= profileUser.role_title %></strong><% } %>
  </p>
</div>

<%- include('../partials/footer') %>
