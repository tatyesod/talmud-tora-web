<%- include('../partials/header', {title: 'בדיקת התאמות במלאי ספרים', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>🔍 בדיקת התאמות - מלאי ספרים</h1>
    <div class="actions">
      <a href="/books/inventory?year=<%= encodeURIComponent(year) %>" class="btn secondary">← חזרה למלאי</a>
      <a href="/books/catalog-manage" class="btn secondary">🔗 שיוך ספר לכיתה</a>
    </div>
  </div>

  <p style="color:var(--muted); margin:10px 0;">
    כדי שספר יופיע נכון בעמודת "הוזמן" במלאי, שם הספר במחירון חייב להיות <strong>זהה אות באות</strong> לשם הספר
    בקטלוג הכיתה (שממנו ההורים מזמינים) וגם בטבלת החידושים. לכל שורה למטה יש שתי דרכי תיקון מהירות: לבחור שזה
    בעצם ספר קיים במחירון בשם אחר (ואז השם בקטלוג יתוקן אוטומטית), או להוסיף אותו כספר חדש בשם המדויק הזה.
  </p>

  <form method="GET" action="/books/inventory/diagnostics" style="margin:14px 0;">
    <label><strong>שנה:</strong></label>
    <select name="year" onchange="this.form.submit()">
      <% years.forEach(y => { %>
        <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
      <% }) %>
    </select>
  </form>

  <% if (catalogMismatches.length === 0 && extrasMismatches.length === 0) { %>
    <div style="background:#e8f5e9; border:1px solid #a5d6a7; color:#2e7d32; border-radius:8px; padding:12px 16px;">
      ✅ לא נמצאו אי-התאמות - כל שמות הספרים בקטלוג ובחידושים תואמים בדיוק למחירון.
    </div>
  <% } else { %>
    <div style="background:#fdecea; border:1px solid #f5c6cb; color:#a94442; border-radius:8px; padding:12px 16px; margin-bottom:16px;">
      ⚠️ נמצאו <%= catalogMismatches.length + extrasMismatches.length %> שמות ספרים שלא תואמים למחירון - ההזמנות שלהם
      <strong>לא נספרות</strong> בעמודת "הוזמן" במלאי, עד שתתקנו אחת מהאפשרויות בכל שורה.
    </div>

    <% if (catalogMismatches.length > 0) { %>
      <h3>קטלוג כיתות (הזמנות רגילות) - <%= catalogMismatches.length %> אי-התאמות</h3>
      <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>שם הספר בקטלוג הכיתה</th><th>כיתה</th><th>הזמנות</th><th>תיקון</th></tr></thead>
        <tbody>
          <% catalogMismatches.forEach(m => { %>
            <tr>
              <td><strong><%= m.item_name %></strong><% if (m.closeMatch) { %><br/><span style="color:#2c5f9e; font-size:0.85em;"><%= m.closeMatch %></span><% } %></td>
              <td><%= m.class_name %></td>
              <td><%= m.order_count %></td>
              <td style="white-space:nowrap;">
                <form method="POST" action="/books/inventory/diagnostics/rename-catalog" style="display:inline-flex; gap:6px; align-items:center;">
                  <input type="hidden" name="old_name" value="<%= m.item_name %>" />
                  <input type="hidden" name="year" value="<%= year %>" />
                  <select name="new_name" required style="max-width:180px;">
                    <option value="">זה בעצם...</option>
                    <% allPriceNames.forEach(n => { %><option value="<%= n %>"><%= n %></option><% }) %>
                  </select>
                  <button type="submit" class="btn small secondary">עדכן שם</button>
                </form>
                <form method="POST" action="/books/inventory/diagnostics/add-as-new" style="display:inline-block; margin-inline-start:6px;">
                  <input type="hidden" name="item_name" value="<%= m.item_name %>" />
                  <input type="hidden" name="publisher" value="<%= m.publisher || '' %>" />
                  <input type="hidden" name="price" value="<%= m.price %>" />
                  <input type="hidden" name="class_name" value="<%= m.class_name %>" />
                  <input type="hidden" name="year" value="<%= year %>" />
                  <button type="submit" class="btn small">+ ספר חדש בשם הזה</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    <% } %>

    <% if (extrasMismatches.length > 0) { %>
      <h3 style="margin-top:20px;">חידושים / הזמנות נוספות - <%= extrasMismatches.length %> אי-התאמות</h3>
      <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>שם הספר בחידוש</th><th>חידושים</th><th>תיקון</th></tr></thead>
        <tbody>
          <% extrasMismatches.forEach(m => { %>
            <tr>
              <td><strong><%= m.item_name %></strong><% if (m.closeMatch) { %><br/><span style="color:#2c5f9e; font-size:0.85em;"><%= m.closeMatch %></span><% } %></td>
              <td><%= m.order_count %></td>
              <td style="white-space:nowrap;">
                <form method="POST" action="/books/inventory/diagnostics/rename-extra" style="display:inline-flex; gap:6px; align-items:center;">
                  <input type="hidden" name="old_name" value="<%= m.item_name %>" />
                  <input type="hidden" name="year" value="<%= year %>" />
                  <select name="new_name" required style="max-width:180px;">
                    <option value="">זה בעצם...</option>
                    <% allPriceNames.forEach(n => { %><option value="<%= n %>"><%= n %></option><% }) %>
                  </select>
                  <button type="submit" class="btn small secondary">עדכן שם</button>
                </form>
                <form method="POST" action="/books/inventory/diagnostics/add-as-new" style="display:inline-block; margin-inline-start:6px;">
                  <input type="hidden" name="item_name" value="<%= m.item_name %>" />
                  <input type="hidden" name="price" value="<%= m.price %>" />
                  <input type="hidden" name="year" value="<%= year %>" />
                  <button type="submit" class="btn small">+ ספר חדש בשם הזה</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
      <p style="color:var(--muted); font-size:0.85em; margin-top:6px;">
        לב חידושים אין כיתה משויכת אוטומטית - אחרי הוספה כספר חדש, כדאי לעבור ל"שיוך ספר לכיתה" ולוודא שהוא משויך לכיתות הנכונות.
      </p>
    <% } %>
  <% } %>

  <% if (orphanedWithOrders.length > 0) { %>
    <h3 style="margin-top:24px;">📌 ספרים עם הזמנות אמיתיות בכיתה שכבר לא משויכת - <%= orphanedWithOrders.length %></h3>
    <p style="color:var(--muted); font-size:0.9em;">
      אלה ספרים שיש עליהם <strong>הזמנה אמיתית</strong> של תלמיד, אבל הכיתה שהזמינה אותם <strong>כבר לא משויכת</strong>
      לספר הזה ב"שיוך ספר לכיתה" (למשל בעקבות תיקון שיוך). המערכת לא מחקה את ההזמנה - זו החלטה שרק אתם יכולים
      לקבל: אם זה בעצם נכון שהכיתה הזו כן צריכה את הספר, לחצו "השאר משויך". אחרת, כדאי לעבור לעמוד ההזמנה של
      הכיתה ולברר עם המשפחה אם ההזמנה הזו בטעות.
    </p>
    <div class="table-scroll-wrap">
    <table>
      <thead><tr><th>ספר</th><th>כיתה</th><th>הזמנות</th><th>פעולה</th></tr></thead>
      <tbody>
        <% orphanedWithOrders.forEach(o => { %>
          <tr>
            <td><%= o.item_name %></td>
            <td><%= o.class_name %></td>
            <td><%= o.order_count %></td>
            <td style="white-space:nowrap;">
              <form method="POST" action="/books/inventory/diagnostics/keep-class-assignment" style="display:inline;">
                <input type="hidden" name="item_name" value="<%= o.item_name %>" />
                <input type="hidden" name="class_name" value="<%= o.class_name %>" />
                <input type="hidden" name="year" value="<%= year %>" />
                <button type="submit" class="btn small secondary">✓ השאר משויך לכיתה זו</button>
              </form>
              <% if (o.class_id) { %>
                <a href="/books/class?year=<%= encodeURIComponent(year) %>&class_id=<%= o.class_id %>" target="_blank" class="btn small secondary" style="margin-inline-start:6px;">פתח עמוד הזמנה</a>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  <% } %>

  <% if (duplicateCatalogRows.length > 0) { %>
    <h3 style="margin-top:24px;">🚨 כפילות ממש בקטלוג הכיתה - <%= duplicateCatalogRows.length %> ספרים</h3>
    <p style="color:var(--muted); font-size:0.9em;">
      אותו ספר מופיע <strong>יותר מפעם אחת</strong> ברשימת ההזמנה של אותה כיתה (בדרך כלל בעקבות מיזוג ספרים במחירון) -
      זה גורם לספר להופיע כפול בעמוד ההזמנה, ולהזמנות האמיתיות להתפצל בין השורות, כך שהמלאי מראה פחות ממה שבאמת הוזמן.
      לחיצה על "אחד" תעביר את כל ההזמנות לשורה אחת ותמחק את הכפולה.
    </p>
    <div class="table-scroll-wrap">
    <table>
      <thead><tr><th>ספר</th><th>כיתה</th><th>שורות קטלוג (עם מס' הזמנות בכל אחת)</th><th></th></tr></thead>
      <tbody>
        <% duplicateCatalogRows.forEach(d => { %>
          <tr>
            <td><%= d.item_name %></td>
            <td><%= d.class_name %></td>
            <td><%= d.rows.map(r => `#${r.catalog_id} (${r.order_count} הזמנות)`).join(' + ') %></td>
            <td>
              <form method="POST" action="/books/inventory/diagnostics/merge-catalog-rows" style="display:inline;" onsubmit="return confirm('לאחד את כל שורות הקטלוג הכפולות של הספר הזה לשורה אחת?');">
                <input type="hidden" name="keep_catalog_id" value="<%= d.rows[0].catalog_id %>" />
                <% d.rows.slice(1).forEach(r => { %>
                  <input type="hidden" name="remove_catalog_id" value="<%= r.catalog_id %>" />
                <% }) %>
                <button type="submit" class="btn small">אחד לשורה אחת</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  <% } %>

  <% if (possibleDuplicates.length > 0) { %>
    <h3 style="margin-top:24px;">⚠️ ספרים כפולים אפשריים במחירון - <%= possibleDuplicates.length %> זוגות</h3>
    <p style="color:var(--muted); font-size:0.9em;">
      אלה שני שמות <strong>שונים</strong> במחירון שדומים מאוד זה לזה - כל אחד בפני עצמו כן נמצא במחירון, ולכן לא הופיע
      למעלה כ"אי-התאמה" - אבל בפועל ההזמנות של אותו ספר מתפצלות בין שתי הרשומות. בחרו איזה שם "שורד" ולחצו מיזוג -
      כל ההזמנות, החידושים, שיוך הכיתות והמלאי בפועל (מסוכם, לא נמחק) יעברו לרשומה השורדת, והכפולה תימחק.
    </p>
    <div class="table-scroll-wrap">
    <table>
      <thead><tr><th>אפשרות א'</th><th>אפשרות ב'</th><th>מיזוג</th></tr></thead>
      <tbody>
        <% possibleDuplicates.forEach(d => { %>
          <tr>
            <td><%= d.a.item_name %> <span style="color:var(--muted); font-size:0.85em;">(<%= d.a.publisher || 'ללא הוצאה' %>, <%= d.a.price %> ₪)</span></td>
            <td><%= d.b.item_name %> <span style="color:var(--muted); font-size:0.85em;">(<%= d.b.publisher || 'ללא הוצאה' %>, <%= d.b.price %> ₪)</span></td>
            <td style="white-space:nowrap;">
              <form method="POST" action="/books/inventory/diagnostics/merge-books" style="display:inline-block;" onsubmit="return confirm('למזג לתוך אפשרות א\\' (' + <%- JSON.stringify(d.a.item_name) %> + ')? אפשרות ב\\' תימחק.');">
                <input type="hidden" name="keep_id" value="<%= d.a.id %>" />
                <input type="hidden" name="remove_id" value="<%= d.b.id %>" />
                <input type="hidden" name="year" value="<%= year %>" />
                <button type="submit" class="btn small secondary">← שמור א', מזג ב'</button>
              </form>
              <form method="POST" action="/books/inventory/diagnostics/merge-books" style="display:inline-block; margin-inline-start:6px;" onsubmit="return confirm('למזג לתוך אפשרות ב\\' (' + <%- JSON.stringify(d.b.item_name) %> + ')? אפשרות א\\' תימחק.');">
                <input type="hidden" name="keep_id" value="<%= d.b.id %>" />
                <input type="hidden" name="remove_id" value="<%= d.a.id %>" />
                <input type="hidden" name="year" value="<%= year %>" />
                <button type="submit" class="btn small secondary">שמור ב', מזג א' →</button>
              </form>
              <span style="color:var(--muted); font-size:0.8em; margin-inline-start:6px;">(אלו לא כפולים? פשוט התעלמו)</span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
