<%- include('../partials/header', {title: 'קטלוג ספרים', wide: true}) %>

<div class="card">
  <div>
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
      <h1>📖 קטלוג ספרים</h1>
      <div class="actions">
        <a href="/books" class="btn secondary">← חזרה</a>
        <a href="/books/inventory" class="btn secondary">📦 מלאי לפי סניף</a>
      </div>
    </div>

    <p style="color:var(--muted); font-size:0.9em; margin:10px 0;">
      זהו <strong>מקור האמת</strong> לשם, הוצאה ומחיר של כל ספר - שינוי כאן מתעדכן אוטומטית בקטלוג ההזמנה של כל הכיתות.
      <strong>כיתות</strong> - קובע לאילו כיתות הספר שייך (למשל "בואו חשבון 1" שייך לכיתה ב'). המערכת כבר יודעת
      באילו סניפים קיימת כל כיתה, ומסננת את מסך "מלאי לפי סניף" אוטומטית בהתאם - אין צורך לציין סניף בנפרד.
    </p>

    <% if (saved) { %>
      <div style="background:#e8f5e9; border:1px solid #a5d6a7; color:#2e7d32; border-radius:8px; padding:10px 16px; margin-bottom:10px;">
        ✅ הקטלוג נשמר בהצלחה.
      </div>
    <% } %>
    <% if (added > 0) { %>
      <div style="background:#e8f5e9; border:1px solid #a5d6a7; color:#2e7d32; border-radius:8px; padding:10px 16px; margin-bottom:10px;">
        ✅ נוספו <%= added %> ספרים חדשים.
      </div>
    <% } %>

    <h3 style="margin:14px 0 8px;">➕ הוספת ספר חדש</h3>
    <form method="POST" action="/books/catalog-manage/add" id="add-books-form">
      <table id="add-books-table">
        <thead><tr><th>שם הספר</th><th>הוצאה</th><th>מחיר (₪)</th><th>הערות</th><th>כיתות</th></tr></thead>
        <tbody id="add-books-tbody">
          <tr>
            <td><input type="text" name="item_name" placeholder="שם הספר" style="min-width:200px;" /></td>
            <td><input type="text" name="publisher" placeholder="הוצאה" style="min-width:120px;" /></td>
            <td><input type="number" name="price" step="0.01" min="0" placeholder="מחיר" style="width:90px;" /></td>
            <td><input type="text" name="notes" placeholder="הערה חופשית (אופציונלי)" style="min-width:140px;" /></td>
            <td>
              <% gradeOptions.forEach(g => { %>
                <label style="display:inline-block; margin-inline-end:10px; font-weight:normal;">
                  <input type="checkbox" name="grades_0" value="<%= g %>" style="width:auto;" /> <%= g %>
                </label>
              <% }) %>
            </td>
          </tr>
        </tbody>
      </table>
      <div class="actions" style="margin-top:10px;">
        <button type="button" class="btn small secondary" onclick="addBookRow()">+ הוסף שורה</button>
        <button type="submit" class="btn small">💾 שמור ספרים חדשים</button>
      </div>
    </form>
  </div>

  <form method="POST" action="/books/catalog-manage/save">
    <div class="actions" style="margin-bottom:14px;">
      <button type="submit" class="btn">💾 שמירת הקטלוג</button>
    </div>
    <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>שם הספר</th><th>הוצאה</th><th>מחיר</th><th>הערות</th><th>כיתות</th></tr></thead>
        <tbody>
          <% books.forEach((b, i) => { %>
            <tr>
              <td style="min-width:220px;">
                <input type="hidden" name="book_price_id" value="<%= b.id %>" />
                <input type="text" name="item_name" value="<%= b.item_name %>" required style="width:100%; min-width:200px;" />
              </td>
              <td><input type="text" name="publisher" value="<%= b.publisher || '' %>" style="min-width:120px;" /></td>
              <td><input type="number" name="price" value="<%= b.price %>" min="0" step="0.01" style="width:80px;" /></td>
              <td><input type="text" name="notes" value="<%= b.notes || '' %>" placeholder="הערה חופשית" style="min-width:140px;" /></td>
              <td style="white-space:nowrap;">
                <% gradeOptions.forEach(g => { %>
                  <label style="display:inline-block; margin-inline-end:10px; font-weight:normal;">
                    <input type="checkbox" name="grades_<%= i %>" value="<%= g %>" <%= b.assignedGrades.includes(g) ? 'checked' : '' %> style="width:auto;" /> <%= g %>
                  </label>
                <% }) %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </form>
</div>

<script>
  function addBookRow() {
    const tbody = document.getElementById('add-books-tbody');
    const rowIndex = tbody.querySelectorAll('tr').length;
    const gradeOptions = <%- JSON.stringify(gradeOptions) %>;
    const checkboxesHtml = gradeOptions.map(g =>
      `<label style="display:inline-block; margin-inline-end:10px; font-weight:normal;"><input type="checkbox" name="grades_${rowIndex}" value="${g}" style="width:auto;" /> ${g}</label>`
    ).join('');
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><input type="text" name="item_name" placeholder="שם הספר" style="min-width:200px;" /></td>
      <td><input type="text" name="publisher" placeholder="הוצאה" style="min-width:120px;" /></td>
      <td><input type="number" name="price" step="0.01" min="0" placeholder="מחיר" style="width:90px;" /></td>
      <td><input type="text" name="notes" placeholder="הערה חופשית (אופציונלי)" style="min-width:140px;" /></td>
      <td>${checkboxesHtml}</td>
    `;
    tbody.appendChild(tr);
  }
</script>

<%- include('../partials/footer') %>
