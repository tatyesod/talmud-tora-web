<%- include('../partials/header', {title: 'בדיקת בריאות מלאה - הזמנת ספרים', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>🩺 בדיקת בריאות מלאה - הזמנת ספרים</h1>
    <div class="actions">
      <a href="/books" class="btn secondary">← חזרה</a>
      <a href="/books/inventory/diagnostics?year=<%= encodeURIComponent(year) %>" class="btn secondary">🔍 בדיקת התאמות רגילה</a>
      <a href="/books/catalog-manage" class="btn secondary">🔗 שיוך ספר לכיתה</a>
    </div>
  </div>

  <form method="GET" action="/books/inventory/health-check" style="margin:14px 0;">
    <label><strong>שנה:</strong></label>
    <select name="year" onchange="this.form.submit()">
      <% years.forEach(y => { %>
        <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
      <% }) %>
    </select>
  </form>

  <% if (issueCount === 0) { %>
    <div style="background:#e8f5e9; border:2px solid #2e7d32; color:#2e7d32; border-radius:10px; padding:16px 20px; margin-bottom:16px; font-size:1.1em;">
      ✅ <strong>הכל תקין!</strong> לא נמצאה אף בעיה בכל הבדיקות (כפילויות, שיוכים חסרים, אי-התאמות שמות). אפשר להוציא הזמנה בביטחון.
    </div>
  <% } else { %>
    <div style="background:#fdecea; border:2px solid #a94442; color:#a94442; border-radius:10px; padding:16px 20px; margin-bottom:16px; font-size:1.1em;">
      ⚠️ נמצאו <strong><%= issueCount %></strong> נקודות שכדאי לעבור עליהן לפני שמוציאים הזמנה - פירוט למטה.
    </div>
  <% } %>

  <div style="background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:14px 18px; margin-bottom:20px;">
    <strong>נתונים גולמיים לשנת <%= year %>:</strong>
    סה"כ <%= totalOrders %> הזמנות ספרים רגילות, <%= totalExtras %> חידושים/הזמנות נוספות.
    <span style="color:var(--muted); font-size:0.9em;">(מספרים אלה - תשווה מול מה שאתה זוכר/מצפה. אם נראה נמוך משמעותית ממה שציפית, זה סימן לבדוק לעומק.)</span>
  </div>

  <h3>📚 סיכום לפי כיתה</h3>
  <p style="color:var(--muted); font-size:0.9em;">
    אם כיתה מראה הרבה תלמידים אבל מעט מאוד הזמנות - ייתכן שחסרות שם עמודות/ספרים. אם כיתה מראה הרבה יותר ספרים
    ("סוגי ספרים") משאר הכיתות - ייתכן שיש שם כפילויות.
  </p>
  <div class="table-scroll-wrap">
    <table>
      <thead><tr><th>כיתה</th><th>תלמידים פעילים</th><th>סוגי ספרים בקטלוג</th><th>סה"כ הזמנות</th></tr></thead>
      <tbody>
        <% perClassSummary.forEach(c => { %>
          <tr>
            <td><%= c.class_name %></td>
            <td><%= c.student_count %></td>
            <td><%= c.book_count %></td>
            <td><%= c.total_orders %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (duplicateCatalogRows.length > 0) { %>
    <h3 style="margin-top:24px; color:#a94442;">🚨 כפילות ממש בקטלוג הכיתה - <%= duplicateCatalogRows.length %></h3>
    <p style="color:var(--muted); font-size:0.9em;">אותו ספר מופיע יותר מפעם אחת באותה כיתה - ההזמנות מתפצלות ביניהן. תיקון מלא ב"בדיקת התאמות רגילה".</p>
    <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>ספר</th><th>כיתה</th><th>שורות</th></tr></thead>
        <tbody>
          <% duplicateCatalogRows.forEach(d => { %>
            <tr><td><%= d.item_name %></td><td><%= d.class_name %></td><td><%= d.rows.map(r => `#${r.catalog_id} (${r.order_count} הזמנות)`).join(' + ') %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <% if (orphanedWithOrders.length > 0) { %>
    <h3 style="margin-top:24px; color:#a94442;">📌 ספרים עם הזמנות אמיתיות בכיתה שכבר לא משויכת - <%= orphanedWithOrders.length %></h3>
    <p style="color:var(--muted); font-size:0.9em;">יש הזמנה אמיתית על ספר בכיתה שכבר לא משויכת אליו. תיקון מלא ב"בדיקת התאמות רגילה".</p>
    <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>ספר</th><th>כיתה</th><th>הזמנות</th></tr></thead>
        <tbody>
          <% orphanedWithOrders.forEach(o => { %>
            <tr><td><%= o.item_name %></td><td><%= o.class_name %></td><td><%= o.order_count %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <% if (catalogMismatches.length > 0 || extrasMismatches.length > 0) { %>
    <h3 style="margin-top:24px; color:#a94442;">⚠️ שמות שלא תואמים למחירון - <%= catalogMismatches.length + extrasMismatches.length %></h3>
    <p style="color:var(--muted); font-size:0.9em;">הזמנות שלא ייספרו במלאי כי השם לא זהה למחירון. תיקון מלא ב"בדיקת התאמות רגילה".</p>
    <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>סוג</th><th>שם</th><th>כיתה</th><th>הזמנות</th></tr></thead>
        <tbody>
          <% catalogMismatches.forEach(m => { %>
            <tr><td>קטלוג כיתה</td><td><%= m.item_name %></td><td><%= m.class_name %></td><td><%= m.order_count %></td></tr>
          <% }) %>
          <% extrasMismatches.forEach(m => { %>
            <tr><td>חידוש</td><td><%= m.item_name %></td><td>-</td><td><%= m.order_count %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <% if (missingCatalogEntries.length > 0) { %>
    <h3 style="margin-top:24px; color:#a94442;">❓ ספר משויך לכיתה אבל חסר בקטלוג ההזמנה - <%= missingCatalogEntries.length %></h3>
    <p style="color:var(--muted); font-size:0.9em;">
      ספר ששויך לכיתה ב"שיוך ספר לכיתה" אבל עדיין לא נוצרה לו שורת קטלוג לשנה זו - ההורים לא רואים אותו בעמוד ההזמנה בכלל.
      פתרון: תיכנס למסך "מלאי ספרים" או "שיוך ספר לכיתה" ושמור שוב (זה יריץ סנכרון וישלים את החסר).
    </p>
    <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>ספר</th><th>כיתה חסרה</th></tr></thead>
        <tbody>
          <% missingCatalogEntries.forEach(m => { %>
            <tr><td><%= m.item_name %></td><td><%= m.class_name %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <% if (possibleDuplicates.length > 0) { %>
    <h3 style="margin-top:24px; color:#8a6d00;">🤔 ספרים כפולים אפשריים במחירון - <%= possibleDuplicates.length %></h3>
    <p style="color:var(--muted); font-size:0.9em;">שני שמות דומים מאוד - ייתכן אותו ספר בשני שמות, וייתכן שני ספרים שונים בכוונה (למשל גרסאות שונות). לבדיקה/מיזוג ב"בדיקת התאמות רגילה".</p>
    <div class="table-scroll-wrap">
      <table>
        <thead><tr><th>אפשרות א'</th><th>אפשרות ב'</th></tr></thead>
        <tbody>
          <% possibleDuplicates.forEach(d => { %>
            <tr><td><%= d.a.item_name %> (<%= d.a.price %> ₪)</td><td><%= d.b.item_name %> (<%= d.b.price %> ₪)</td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
