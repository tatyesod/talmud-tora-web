<%- include('../partials/header', {title: 'מחירון ספרים'}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>💰 מחירון ספרים</h1>
    <div class="actions">
      <a href="/books" class="btn secondary">חזרה להזמנות</a>
      <a href="/books/catalog" class="btn secondary">קטלוג שנתי</a>
    </div>
  </div>

  <% if (saved) { %><div class="alert-success" style="background:#eef6ee; border:1px solid #bcd9bc; border-radius:8px; padding:9px 14px; margin-bottom:14px; color:#2d7a2d;">✅ המחירון עודכן!</div><% } %>

  <p style="color:var(--muted); font-size:0.9em;">
    עדכון מחיר כאן <strong>יעדכן אוטומטית</strong> את כל הפריטים בעלי שם דומה בקטלוג השנתי.
  </p>

  <h3>הוספת פריט חדש למחירון</h3>
  <form method="POST" action="/books/pricelist" class="form-grid" style="margin-bottom:24px;">
    <div class="form-group"><label>שם הפריט</label><input type="text" name="item_name" required /></div>
    <div class="form-group"><label>מחיר (₪)</label><input type="number" step="0.01" name="price" required /></div>
    <div class="form-group"><label>הוצאה</label><input type="text" name="publisher" /></div>
    <div class="form-group full"><button type="submit" class="btn small">+ הוסף</button></div>
  </form>

  <h3>מחירון נוכחי (<%= items.length %> פריטים)</h3>
  <div class="table-scroll-wrap">
  <table>
    <thead><tr><th>שם הפריט</th><th>הוצאה</th><th>מחיר</th><th>עדכון אחרון</th><th></th></tr></thead>
    <tbody>
      <% items.forEach(item => { %>
        <tr>
          <td><strong><%= item.item_name %></strong></td>
          <td><%= item.publisher || '' %></td>
          <td>
            <form method="POST" action="/books/pricelist/<%= item.id %>/update" style="display:inline-flex; gap:6px; align-items:center;">
              <input type="number" step="0.01" name="price" value="<%= item.price %>" style="width:80px; padding:3px 6px;" />
              <input type="text" name="publisher" value="<%= item.publisher||'' %>" style="width:140px; padding:3px 6px;" placeholder="הוצאה" />
              <button type="submit" class="btn small">עדכן</button>
            </form>
          </td>
          <td style="font-size:0.82em; color:var(--muted);"><%= item.updated_at ? new Date(item.updated_at).toLocaleDateString('he-IL') : '' %></td>
          <td>
            <form method="POST" action="/books/pricelist/<%= item.id %>?_method=DELETE" onsubmit="return confirm('למחוק?');" style="display:inline">
              <button type="submit" class="btn small danger">✕</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
</div>

<%- include('../partials/footer') %>
