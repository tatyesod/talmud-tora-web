<%- include('../partials/header', {title: 'צפייה בקטלוג', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>👁️ צפייה בקטלוג הזמנות</h1>
    <div class="actions">
      <a href="/books" class="btn secondary">← חזרה להזמנות</a>
      <a href="/books/catalog-manage" class="btn">🔗 שיוך ספר לכיתה</a>
    </div>
  </div>

  <p style="color:var(--muted); font-size:0.9em;">
    זהו מסך <strong>צפייה בלבד</strong> - מראה אילו ספרים מופיעים בפועל בקטלוג ההזמנה של כל כיתה, לפי שנה. הנתונים
    האלה נבנים <strong>אוטומטית</strong> ממסך "🔗 שיוך ספר לכיתה" - כדי להוסיף/להסיר/לשנות ספר, יש לעבור לשם
    (זה המקום היחיד לעריכת שם, הוצאה, מחיר ושיוך כיתה).
  </p>

  <form class="searchbar" method="GET" action="/books/catalog-and-prices" style="margin:14px 0;">
    <label><strong>שנה:</strong></label>
    <select name="year" onchange="this.form.submit()">
      <% years.forEach(y => { %>
        <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
      <% }) %>
    </select>
  </form>

  <% const classNames = Object.keys(grouped); %>
  <% if (classNames.length === 0) { %>
    <p class="empty-state">אין עדיין ספרים בקטלוג לשנה זו - שייכו ספרים לכיתות דרך "🔗 שיוך ספר לכיתה".</p>
  <% } else { %>
    <% classNames.forEach(className => { %>
      <h3 style="margin-top:22px; border-bottom:1px solid var(--border); padding-bottom:6px;"><%= className %> (<%= grouped[className].length %> ספרים)</h3>
      <table>
        <thead><tr><th>ספר</th><th>הוצאה</th><th>מחיר</th></tr></thead>
        <tbody>
          <% grouped[className].forEach(c => { %>
            <tr>
              <td><%= c.item_name %></td>
              <td><%= c.publisher || '' %></td>
              <td><%= c.price %> ₪</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% }) %>
  <% } %>
</div>

<%- include('../partials/footer') %>
