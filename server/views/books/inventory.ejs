<%- include('../partials/header', {title: 'מלאי ספרים', wide: true}) %>

<div class="card">
  <div>
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
      <h1>📦 מלאי ספרים</h1>
      <div class="actions">
        <a href="/books" class="btn secondary">← חזרה</a>
        <button type="button" class="btn secondary" onclick="window.print()">🖨️ הדפס</button>
        <a href="/books/inventory/print?branch=<%= encodeURIComponent(branch) %>&year=<%= encodeURIComponent(year) %>" class="btn secondary" target="_blank">🖨️ דוח ספירה למילוי ידני</a>
        <a href="/books/inventory/diagnostics?year=<%= encodeURIComponent(year) %>" class="btn secondary">🔍 בדיקת התאמות</a>
        <a href="/books/inventory/order?branch=<%= encodeURIComponent(branch) %>&year=<%= encodeURIComponent(year) %>" class="btn">🛒 מעבר להזמנה מהספק</a>
      </div>
    </div>

    <form method="GET" action="/books/inventory" style="margin:10px 0; display:flex; gap:14px; flex-wrap:wrap; align-items:center;">
      <span><label><strong>סניף:</strong></label>
        <select name="branch" onchange="this.form.submit()">
          <% branches.forEach(b => { %>
            <option value="<%= b %>" <%= b === branch ? 'selected' : '' %>><%= b %></option>
          <% }) %>
        </select>
      </span>
      <span><label><strong>שנת לימודים:</strong></label>
        <select name="year" onchange="this.form.submit()">
          <% years.forEach(y => { %>
            <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
          <% }) %>
        </select>
      </span>
    </form>

    <% if (saved) { %>
      <div style="background:#e8f5e9; border:1px solid #a5d6a7; color:#2e7d32; border-radius:8px; padding:10px 16px; margin-bottom:10px;">
        ✅ המלאי נשמר בהצלחה.
      </div>
    <% } %>
  </div>

  <p style="color:var(--muted); font-size:0.9em; margin-top:16px;">
    שם הספר, הוצאה, מחיר וכיתות השיוך <strong>נקבעים במסך "שיוך ספר לכיתה"</strong> (בדף הראשי של הזמנת ספרים) - כאן ניתן לעדכן רק
    <strong>מלאי נוכחי</strong> ו<strong>תוספת</strong> (כמות שתרצו להוסיף מעבר למה שהוזמן בפועל, ברירת מחדל 5 יח').
    <strong>הוזמן</strong> - כמה תלמידים בפועל הזמינו את הספר (מתוך "הזמנת ספרים" לפי כיתות, לסניף ולשנה שנבחרו).
    <strong>כמות להזמנה</strong> מחושבת אוטומטית: הוזמן + תוספת - מלאי נוכחי.
  </p>

  <% if (items.length === 0) { %>
    <p class="empty-state">אין ספרים המשויכים לסניף זה - שייכו ספרים לכיתות דרך "שיוך ספר לכיתה" בדף הראשי של הזמנת ספרים.</p>
  <% } else { %>
    <form method="POST" action="/books/inventory/save">
      <input type="hidden" name="branch" value="<%= branch %>" />
      <input type="hidden" name="year" value="<%= year %>" />
      <div class="actions" style="margin-bottom:14px;">
        <button type="submit" class="btn">💾 שמירת מלאי לסניף <%= branch %></button>
      </div>
      <div class="table-scroll-wrap">
        <table>
          <thead><tr>
            <th>ספר</th><th>הוצאה</th><th>הערות</th><th>מחיר</th>
            <th>מלאי נוכחי</th><th>הוזמן</th><th>תוספת</th><th>כמות להזמנה</th>
          </tr></thead>
          <tbody>
            <% items.forEach((it, i) => { %>
              <tr>
                <td style="min-width:200px;">
                  <input type="hidden" name="book_price_id" value="<%= it.book_price_id %>" />
                  <%= it.item_name %>
                </td>
                <td><%= it.publisher || '' %></td>
                <td style="color:var(--muted); font-size:0.9em;"><%= it.notes || '' %></td>
                <td><%= it.price %> ₪</td>
                <td><input type="number" class="current-stock" data-row="<%= i %>" name="current_stock" value="<%= it.current_stock %>" min="0" style="width:90px;" /></td>
                <td style="text-align:center; color:var(--muted);"><%= it.ordered_count %></td>
                <td><input type="number" class="extra-qty" data-row="<%= i %>" name="extra_quantity" value="<%= it.extra_quantity %>" min="0" style="width:90px;" /></td>
                <td class="to-order-cell" data-row="<%= i %>" data-ordered="<%= it.ordered_count %>" style="text-align:center; font-weight:700;"><%= it.to_order %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </form>
  <% } %>
</div>

<script>
  function recomputeRow(rowIndex) {
    const stockInput = document.querySelector('.current-stock[data-row="' + rowIndex + '"]');
    const extraInput = document.querySelector('.extra-qty[data-row="' + rowIndex + '"]');
    const cell = document.querySelector('.to-order-cell[data-row="' + rowIndex + '"]');
    if (!stockInput || !extraInput || !cell) return;
    const ordered = parseInt(cell.getAttribute('data-ordered'), 10) || 0;
    const stock = parseInt(stockInput.value, 10) || 0;
    const extra = parseInt(extraInput.value, 10) || 0;
    cell.textContent = ordered + extra - stock;
  }

  document.querySelectorAll('.current-stock, .extra-qty').forEach((input) => {
    input.addEventListener('input', () => recomputeRow(input.getAttribute('data-row')));
  });
</script>

<%- include('../partials/footer') %>
