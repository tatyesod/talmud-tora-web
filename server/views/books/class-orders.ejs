<%- include('../partials/header', {title: 'הזמנות — ' + cls.name + ' ' + (cls.parallel||''), wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>הזמנות — <%= cls.name %> <%= cls.parallel %> &nbsp;|&nbsp; שנת <%= year %></h1>
    <div class="actions">
      <a href="/books?year=<%= encodeURIComponent(year) %>" class="btn secondary">חזרה</a>
      <a href="/books/report/class?year=<%= encodeURIComponent(year) %>&class_id=<%= cls.id %>" class="btn secondary">📥 ייצוא אקסל</a>
    </div>
  </div>

  <% if (saved) { %>
    <div style="background:#eef6ee; border:1px solid #bcd9bc; border-radius:8px; padding:10px 16px; margin-bottom:14px; color:#2d7a2d;">✅ ההזמנות נשמרו בהצלחה!</div>
  <% } %>

  <% if (students.length === 0) { %>
    <p class="empty-state">אין תלמידים פעילים בכיתה זו</p>
  <% } else { %>
  <div class="orders-save-bar">
    <button type="submit" form="orders-form" class="btn">💾 שמירת הזמנות</button>
    <a href="/books?year=<%= encodeURIComponent(year) %>" class="btn secondary">ביטול</a>
  </div>

  <p style="color:var(--muted); font-size:0.88em; margin-bottom:10px;">
    לחץ על תא לסימון/ביטול הזמנה. לחיצה על כותרת עמודה = מסמן/מבטל את כולם.
  </p>
  <div class="table-scroll-wrap" style="overflow-x:auto;">
    <form method="POST" action="/books/class/save" id="orders-form">
      <input type="hidden" name="year" value="<%= year %>" />
      <input type="hidden" name="class_id" value="<%= cls.id %>" />

      <table class="books-table">
        <thead>
          <tr>
            <th class="student-col">תלמיד</th>
            <% catalog.forEach((c, idx) => { %>
              <th class="book-col" data-col="<%= idx %>" title="<%= c.publisher || '' %>">
                <%= c.item_name %>
                <div class="book-price"><%= c.price %> ₪</div>
              </th>
            <% }) %>
            <th class="total-col">סה"כ ₪</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(s => { %>
            <tr class="student-row" data-student="<%= s.id %>">
              <td class="student-name">
                <div class="student-name-row">
                  <strong><%= s.last_name || s.family_last || '' %> <%= s.first_name %></strong>
                  <% if (s.family_id) { %>
                    <a href="/books/payments?year=<%= encodeURIComponent(year) %>#fam-<%= s.family_id %>" class="student-pay-link" title="מעבר לתשלום המשפחה">💳</a>
                  <% } %>
                </div>
                <% const addr = [s.street, s.house_number].filter(Boolean).join(' '); %>
                <% if (addr) { %><div class="student-address"><%= addr %></div><% } %>
              </td>
              <% let rowTotal = 0; catalog.forEach(c => {
                const checked = ordersMap[s.id] && ordersMap[s.id].has(c.id);
                if (checked) rowTotal += c.price;
              %>
                <td class="book-cell <%= checked ? 'checked' : '' %>" onclick="toggleCell(this)">
                  <input type="checkbox" name="orders" value="<%= s.id %>_<%= c.id %>" <%= checked ? 'checked' : '' %> />
                  <span class="check-mark"><%= checked ? '✓' : '' %></span>
                </td>
              <% }) %>
              <td class="row-total"><%= rowTotal > 0 ? rowTotal : '' %></td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <th>כמות מוזמנים</th>
            <% catalog.forEach(c => {
              const cnt = students.filter(s => ordersMap[s.id] && ordersMap[s.id].has(c.id)).length;
            %>
              <th class="col-count"><%= cnt || '' %></th>
            <% }) %>
            <th id="grand-total">
              <%= students.reduce((sum,s) => sum+catalog.reduce((s2,c) => s2+(ordersMap[s.id]&&ordersMap[s.id].has(c.id)?c.price:0),0),0) || '' %>
            </th>
          </tr>
        </tfoot>
      </table>
    </form>
  </div>
  <% } %>
</div>

<style>
.orders-save-bar {
  position: sticky;
  top: 66px;
  z-index: 20;
  display: flex;
  gap: 10px;
  background: var(--card-bg);
  padding: 10px 14px;
  border-radius: 10px;
  border: 1px solid var(--border);
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  margin-bottom: 14px;
  width: fit-content;
}
.books-table { border-collapse: collapse; font-size: 0.87em; }
.books-table th, .books-table td { border: 1px solid var(--border); padding: 5px 7px; text-align: center; }
.student-col { min-width: 190px; max-width: 240px; text-align: right !important; background: #f8f9fa; position: sticky; right: 0; z-index: 2; }
.student-name { max-width: 240px; text-align: right !important; background: #fff; position: sticky; right: 0; z-index: 1; border-right: 2px solid #dee2e6 !important; }
.student-address { font-size: 0.85em; color: var(--muted); font-weight: 400; margin-top: 2px; }
.student-name-row { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
.student-pay-link { text-decoration: none; font-size: 1em; opacity: 0.7; flex-shrink: 0; }
.student-pay-link:hover { opacity: 1; }
.book-col { min-width: 100px; max-width: 130px; font-size: 0.80em; background: #f0f4f8; vertical-align: bottom; cursor: pointer; }
.book-col:hover { background: #dde8f0; }
.book-price { font-weight: 700; color: var(--primary); font-size: 0.95em; margin-top: 2px; }
.book-cell { cursor: pointer; user-select: none; font-size: 1.3em; color: #2e7d32; font-weight: 700; width: 42px; }
.book-cell:hover { background: #e8f5e9 !important; }
.book-cell.checked { background: #e8f5e9; }
.book-cell input[type="checkbox"] { display: none; }
.total-col, .row-total { font-weight: 700; color: var(--primary-dark); min-width: 65px; background: #f8f9fa; }
tfoot th { background: #f0f4f8; font-weight: 700; }
</style>

<script>
const prices = { <% catalog.forEach(c => { %>"<%= c.id %>": <%= c.price %>, <% }) %> };

function toggleCell(td) {
  const cb = td.querySelector("input");
  const mark = td.querySelector(".check-mark");
  cb.checked = !cb.checked;
  mark.textContent = cb.checked ? "✓" : "";
  td.classList.toggle("checked", cb.checked);
  updateTotals();
}

document.querySelectorAll('.book-col').forEach((th, idx) => {
  th.addEventListener('click', () => {
    const cells = document.querySelectorAll(`.student-row td.book-cell:nth-child(${idx + 2})`);
    const allChecked = [...cells].every(td => td.querySelector('input').checked);
    cells.forEach(td => {
      const cb = td.querySelector('input'), mark = td.querySelector('.check-mark');
      cb.checked = !allChecked; mark.textContent = cb.checked ? '✓' : '';
      td.classList.toggle('checked', cb.checked);
    });
    updateTotals();
  });
});

function updateTotals() {
  let grand = 0;
  document.querySelectorAll('.student-row').forEach(row => {
    let total = 0;
    row.querySelectorAll('.book-cell input:checked').forEach(cb => { total += prices[cb.value.split('_')[1]] || 0; });
    grand += total;
    row.querySelector('.row-total').textContent = total > 0 ? total : '';
  });
  const gt = document.getElementById('grand-total');
  if (gt) gt.textContent = grand > 0 ? grand : '';
}
</script>

<%- include('../partials/footer') %>
