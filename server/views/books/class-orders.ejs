<%- include('../partials/header', {title: 'הזמנות ספרים — ' + class_name}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>הזמנות ספרים — <%= class_name %> | שנת <%= year %></h1>
    <div class="actions">
      <a href="/books?year=<%= encodeURIComponent(year) %>" class="btn secondary">חזרה</a>
      <a href="/books/report/class?year=<%= encodeURIComponent(year) %>&class_name=<%= encodeURIComponent(class_name) %>" class="btn secondary">📥 ייצוא אקסל</a>
    </div>
  </div>

  <% if (typeof req !== 'undefined' && req.query && req.query.saved) { %>
    <div class="alert-success" style="background:#eef6ee; border:1px solid #bcd9bc; border-radius:8px; padding:10px 16px; margin-bottom:14px; color:#2d7a2d;">
      ✅ ההזמנות נשמרו בהצלחה!
    </div>
  <% } %>

  <% if (students.length === 0) { %>
    <p class="empty-state">אין תלמידים פעילים בכיתה זו</p>
  <% } else { %>

  <div style="overflow-x:auto;">
    <form method="POST" action="/books/class/save" id="orders-form">
      <input type="hidden" name="year" value="<%= year %>" />
      <input type="hidden" name="class_name" value="<%= class_name %>" />

      <table class="books-table">
        <thead>
          <tr>
            <th class="student-col">תלמיד</th>
            <% catalog.forEach(c => { %>
              <th class="book-col" title="<%= c.publisher ? c.publisher : '' %>">
                <%= c.item_name %>
                <div class="book-price"><%= c.price %> ₪</div>
              </th>
            <% }) %>
            <th class="total-col">סה"כ ₪</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(s => { %>
            <tr class="student-row" data-student="<%= s.id %>">
              <td class="student-name">
                <strong><%= s.first_name %> <%= s.last_name || s.family_last || '' %></strong>
                <% if (s.parallel) { %><small class="text-muted"> (<%= s.parallel %>)</small><% } %>
              </td>
              <% let rowTotal = 0; catalog.forEach(c => {
                const checked = ordersMap[s.id] && ordersMap[s.id].has(c.id);
                if (checked) rowTotal += c.price;
              %>
                <td class="book-cell" onclick="toggleCell(this)">
                  <input type="checkbox" name="orders" value="<%= s.id %>_<%= c.id %>"
                    <%= checked ? 'checked' : '' %> />
                  <span class="check-mark"><%= checked ? '✓' : '' %></span>
                </td>
              <% }) %>
              <td class="row-total" data-base="0">
                <%= rowTotal > 0 ? rowTotal : '' %>
              </td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <th>סה"כ מוזמנים</th>
            <% catalog.forEach(c => {
              const count = students.filter(s => ordersMap[s.id] && ordersMap[s.id].has(c.id)).length;
            %>
              <th class="col-count"><%= count || '' %></th>
            <% }) %>
            <th id="grand-total">
              <% const grand = students.reduce((sum, s) => sum + catalog.reduce((s2,c) => s2 + (ordersMap[s.id] && ordersMap[s.id].has(c.id) ? c.price : 0), 0), 0); %>
              <%= grand > 0 ? grand : '' %>
            </th>
          </tr>
        </tfoot>
      </table>

      <div class="actions" style="margin-top:16px;">
        <button type="submit" class="btn">💾 שמירת הזמנות</button>
        <a href="/books?year=<%= encodeURIComponent(year) %>" class="btn secondary">ביטול</a>
      </div>
    </form>
  </div>
  <% } %>
</div>

<style>
.books-table { border-collapse: collapse; min-width: 100%; font-size: 0.88em; }
.books-table th, .books-table td { border: 1px solid var(--border); padding: 6px 8px; text-align: center; }
.student-col { min-width: 160px; text-align: right !important; background: #f8f9fa; position: sticky; right: 0; z-index: 1; }
.student-name { text-align: right !important; background: #fff; position: sticky; right: 0; }
.book-col { min-width: 110px; max-width: 130px; font-size: 0.82em; background: #f0f4f8; vertical-align: bottom; }
.book-price { font-weight: 700; color: var(--primary); font-size: 1em; margin-top: 2px; }
.book-cell { cursor: pointer; user-select: none; font-size: 1.3em; color: var(--success); font-weight: 700; }
.book-cell:hover { background: #e8f5e9; }
.book-cell input[type="checkbox"] { display: none; }
.book-cell.checked { background: #e8f5e9; }
.total-col, .row-total { font-weight: 700; color: var(--primary-dark); min-width: 70px; }
tfoot th { background: #f0f4f8; font-weight: 700; }
.col-count { color: #555; }
</style>

<script>
const prices = {
  <% catalog.forEach(c => { %>"<%= c.id %>": <%= c.price %>,<% }) %>
};

function toggleCell(td) {
  const cb = td.querySelector("input[type=checkbox]");
  const mark = td.querySelector(".check-mark");
  cb.checked = !cb.checked;
  mark.textContent = cb.checked ? "✓" : "";
  td.classList.toggle("checked", cb.checked);
  updateTotals();
}

// סימון כל עמודה בלחיצה על כותרת
document.querySelectorAll('.book-col').forEach((th, idx) => {
  th.style.cursor = 'pointer';
  th.title = 'לחץ לסימון/ביטול כל העמודה';
  th.addEventListener('click', () => {
    const cells = document.querySelectorAll(`.student-row td.book-cell:nth-child(${idx + 2})`);
    const allChecked = [...cells].every(td => td.querySelector('input').checked);
    cells.forEach(td => {
      const cb = td.querySelector('input');
      const mark = td.querySelector('.check-mark');
      cb.checked = !allChecked;
      mark.textContent = !allChecked ? '✓' : '';
      td.classList.toggle('checked', !allChecked);
    });
    updateTotals();
  });
});

function updateTotals() {
  let grand = 0;
  document.querySelectorAll('.student-row').forEach(row => {
    let total = 0;
    row.querySelectorAll('.book-cell input:checked').forEach(cb => {
      const cid = cb.value.split('_')[1];
      total += prices[cid] || 0;
    });
    grand += total;
    const totCell = row.querySelector('.row-total');
    if (totCell) totCell.textContent = total > 0 ? total : '';
  });
  const gtEl = document.getElementById('grand-total');
  if (gtEl) gtEl.textContent = grand > 0 ? grand : '';
}

// סימון תאים קיימים
document.querySelectorAll('.book-cell input:checked').forEach(cb => {
  cb.closest('.book-cell').classList.add('checked');
});
</script>

<%- include('../partials/footer') %>
