<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %></title>
  <style>
    * { box-sizing:border-box; margin:0; padding:0; }
    body { font-family: Arial, 'Arial Hebrew', sans-serif; direction:rtl; font-size:9pt; }
    @page { size: A4 portrait; margin: 12mm; }
    @media print { .no-print { display:none; } }
    .no-print { background:#2c5f7c; color:#fff; padding:10px 16px; display:flex; gap:12px; align-items:center; }
    .no-print button { background:#fff; color:#2c5f7c; border:none; border-radius:6px; padding:6px 14px; cursor:pointer; font-weight:700; }
    .no-print a { color:#fff; }
    .header { display:flex; justify-content:space-between; align-items:center; border-bottom:2pt solid #2c5f7c; padding-bottom:6px; margin-bottom:8px; }
    .header h2 { font-size:13pt; color:#2c5f7c; }
    .logo { height:45px; }
    .date { font-size:8pt; color:#666; }
    table { width:100%; border-collapse:collapse; font-size:8.5pt; }
    th { background:#2c5f7c; color:#fff; padding:4px 6px; text-align:right; white-space:nowrap; }
    td { border:0.5pt solid #bbb; padding:3px 6px; text-align:right; }
    tr:nth-child(even) td { background:#f5f8fb; }
    .bsd { text-align:left; font-size:8pt; margin-bottom:3px; }
    .footer { font-size:7pt; color:#888; margin-top:8px; }
  </style>
</head>
<body>

<div class="no-print">
  <button onclick="window.print()">🖨️ הדפסה / שמור PDF</button>
  <span><%= rows.length %> רשומות</span>
  <a href="javascript:history.back()">← חזרה</a>
</div>

<div class="bsd">בס"ד</div>

<div class="header">
  <img src="/images/logo-reports.jpg" class="logo" alt="לוגו"/>
  <h2><%= title %></h2>
  <div class="date">
    <strong>תלמוד תורה החדש</strong><br/>
    <%= new Date().toLocaleDateString('he-IL') %>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th>#</th>
      <% headers.forEach(h => { %><th><%= h %></th><% }) %>
    </tr>
  </thead>
  <tbody>
    <% rows.forEach((row, i) => { %>
      <tr>
        <td><%= i+1 %></td>
        <% row.forEach(cell => { %><td><%= cell != null ? cell : '' %></td><% }) %>
      </tr>
    <% }) %>
  </tbody>
</table>

<div class="footer">הופק ממערכת ניהול תלמוד תורה החדש &nbsp;|&nbsp; <%= new Date().toLocaleString('he-IL') %></div>

</body>
</html>
