<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>הצהרת בריאות</title>
  <style>
    @page {
      size: A4;
      margin: 14mm 16mm;
    }
    * { box-sizing: border-box; }
    body {
      font-family: "Segoe UI", "Arial Hebrew", Arial, sans-serif;
      direction: rtl;
      margin: 0;
      color: #1a1a1a;
      font-size: 15px;
    }
    .page {
      max-width: 850px;
      margin: 0 auto;
      padding: 18px 30px;
      page-break-after: always;
    }
    .page:last-child { page-break-after: auto; }

    .form-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 3px solid #2c5f7c;
      padding-bottom: 10px;
      margin-bottom: 12px;
    }
    .form-header img { height: 62px; }
    .form-header .school-info { text-align: left; font-size: 0.85em; color: #555; line-height: 1.5; }
    .bsd { text-align: left; font-size: 0.85em; color: #888; }

    h2.form-title { text-align: center; margin: 8px 0 4px; font-size: 1.5em; text-decoration: underline; }
    h3.form-subtitle { text-align: center; margin: 0 0 14px; font-size: 1.1em; font-weight: 600; text-decoration: underline; }
    .school-line { text-align: center; font-size: 0.92em; margin-bottom: 16px; }

    table.fields { width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 0.92em; }
    table.fields td { padding: 7px 8px; vertical-align: bottom; line-height: 1.4; }
    table.fields td.label { color: #555; font-size: 0.9em; white-space: nowrap; }
    table.fields td.value { border-bottom: 1.5px solid #888; min-width: 70px; font-weight: 600; }

    .section-title { font-weight: 700; margin: 18px 0 8px; text-decoration: underline; font-size: 1.05em; color: #2c5f7c; }

    .declaration { font-size: 0.9em; line-height: 1.9; }
    .declaration .row { margin-bottom: 10px; }
    .declaration .sub-row { margin-right: 26px; }
    .checkbox { display: inline-block; width: 1.3em; font-size: 1.05em; }
    .free-text { border-bottom: 1.3px dotted #888; padding: 0 6px; font-weight: 600; display: inline-block; min-width: 150px; }
    .free-line { border-bottom: 1.3px dotted #888; display: block; height: 1.8em; margin: 6px 0; }

    .sign-row {
      display: flex; justify-content: space-between; margin-top: 30px; font-size: 0.92em;
    }
    .sign-row div { width: 30%; text-align: center; }
    .sign-line { border-top: 1.3px solid #444; margin-top: 34px; padding-top: 6px; }

    .parent-approval {
      margin-top: 26px; padding-top: 16px; border-top: 2.5px solid #2c5f7c;
    }
    .approval-table { width: 100%; border-collapse: collapse; margin-top: 14px; font-size: 0.92em; }
    .approval-table th, .approval-table td { border: 1.3px solid #888; padding: 16px 10px; text-align: center; }

    @media print {
      .page { padding: 10px 24px; }
    }
  </style>
</head>
<body onload="window.print()">
  <% students.forEach(s => { %>

  <!-- ===== עמוד 1: פרטים מזהים + תחילת הצהרת בריאות ===== -->
  <div class="page">
    <div class="form-header">
      <img src="/images/logo-reports.jpg" alt="לוגו" />
      <div class="school-info">
        תלמוד תורה החדש (יסוד העולם)<br />
        כתובת: סוקולוב 5, בני ברק<br />
        טל: 03-6185020 | פקס: 03-6185030
      </div>
    </div>
    <div class="bsd">בס"ד</div>

    <h2 class="form-title">טופס הצהרת ההורים</h2>
    <h3 class="form-subtitle">על מצב בריאותו של ילדם הלומד בתלמוד תורה</h3>
    <div class="school-line">שם התלמוד תורה: <strong>תלמוד תורה החדש (יסוד העולם)</strong> &nbsp; הישוב: <strong>בני ברק</strong></div>

    <table class="fields">
      <tr>
        <td class="label">פרטי התלמיד:</td>
        <td class="value" colspan="3"><%= s.first_name %> <%= s.last_name %></td>
      </tr>
      <tr>
        <td class="label">מס' ת"ז</td><td class="value"><%= s.id_number || '' %></td>
        <td class="label">שם חיבה</td><td class="value"><%= s.nickname || '' %></td>
      </tr>
      <tr>
        <td class="label">כיתה</td>
        <td class="value"><%= s.class_name ? s.class_name + (s.class_parallel ? ' ('+s.class_parallel+')' : '') : '' %></td>
        <td class="label">קופ"ח</td><td class="value"><%= s.health_fund || '' %></td>
      </tr>
      <tr>
        <td class="label">ת. לידה עברי</td><td class="value"><%= s.birth_date_hebrew_str || '' %></td>
        <td class="label">ת. לידה לועזי</td><td class="value"><%= s.birth_date_civil_str || '' %></td>
      </tr>
      <tr>
        <td class="label">ארץ הלידה</td><td class="value"><%= s.birth_country || 'ישראל' %></td>
        <td class="label">שנת העלייה</td><td class="value"><%= s.birth_country !== 'ישראל' ? (s.immigration_year || '') : '—' %></td>
      </tr>
      <tr>
        <td class="label">מס' ילדים במשפחה</td><td class="value" colspan="3"><%= s.siblings_count || '' %></td>
      </tr>
      <tr>
        <td class="label">הכתובת</td><td class="value" colspan="3"><%= s.address || '' %></td>
      </tr>
      <tr>
        <td class="label">טלפון בבית</td><td class="value" colspan="3"><%= s.home_phone || '' %></td>
      </tr>
      <tr>
        <td class="label">שם האב</td><td class="value"><%= s.father_name || '' %></td>
        <td class="label">עיסוק האב</td><td class="value"><%= s.father_workplace || '' %></td>
      </tr>
      <tr>
        <td class="label">נייד האב</td><td class="value"><%= s.father_mobile || '' %></td>
        <td class="label">טלפון בעבודה</td><td class="value"><%= s.father_work_phone || '' %></td>
      </tr>
      <tr>
        <td class="label">שם האם</td><td class="value"><%= s.mother_name || '' %></td>
        <td class="label">עיסוק האם</td><td class="value"><%= s.mother_workplace || '' %></td>
      </tr>
      <tr>
        <td class="label">נייד האם</td><td class="value"><%= s.mother_mobile || '' %></td>
        <td class="label">טלפון בעבודה</td><td class="value"><%= s.mother_work_phone || '' %></td>
      </tr>
      <tr>
        <td class="label">אימייל האב</td><td class="value"><%= s.father_email || '' %></td>
        <td class="label">אימייל האם</td><td class="value"><%= s.mother_email || '' %></td>
      </tr>
      <tr>
        <td class="label" colspan="4">שם, הכתובת ומספר הטלפון לפנייה בשעת מצוקה כשאחד מן ההורים לא זמין:</td>
      </tr>
      <tr>
        <td class="value" colspan="4">
          <%= s.emergency_contact ? `${s.emergency_contact.contact_name || ''} (${s.emergency_contact.relation || ''}) — ${[s.emergency_contact.phone1, s.emergency_contact.phone2].filter(Boolean).join(' / ')}` : '' %>
        </td>
      </tr>
    </table>

    <div class="section-title">הריני מצהיר/ה כי (סמן את האפשרות הנכונה):</div>
    <div class="declaration">
      <div class="row">
        <span class="checkbox"><%= s.hasHealthIssue ? '☐' : '☑' %></span>
        לא ידוע לי על מגבלות בריאותיות המונעות מבני להשתתף בפעילויות הנערכות בת"ת ומטעמו.
      </div>
      <div class="row">
        <span class="checkbox">☐</span>
        יש לבני מגבלות בריאותיות המונעות השתתפות מלאה/חלקית בפעילות בת"ת ומטעמו, כדלקמן:
      </div>
      <div class="sub-row">☐ פעילות גופנית &nbsp;&nbsp;&nbsp; ☐ הליכה לגינות &nbsp;&nbsp;&nbsp; ☐ פעילות אחרת: <span class="free-text">&nbsp;</span></div>
      <div class="row">תיאור המגבלה: <span class="free-line"></span></div>
      <div class="row sub-row">לפיכך מצורף אישור רפואי שניתן על-ידי: <span class="free-text">&nbsp;</span> &nbsp; לתקופה: <span class="free-text">&nbsp;</span></div>
    </div>
  </div>

  <!-- ===== עמוד 2: המשך הצהרת בריאות ===== -->
  <div class="page">
    <div class="form-header">
      <img src="/images/logo-reports.jpg" alt="לוגו" />
      <div class="school-info">
        תלמוד תורה החדש (יסוד העולם)<br />
        כתובת: סוקולוב 5, בני ברק<br />
        טל: 03-6185020 | פקס: 03-6185030
      </div>
    </div>
    <div class="bsd">בס"ד</div>
    <div style="text-align:center; font-size:0.95em; color:#555; margin-bottom:10px;">
      המשך טופס הצהרת ההורים — <%= s.first_name %> <%= s.last_name %>
    </div>

    <div class="declaration">
      <div class="row">
        <span class="checkbox">☐</span> לא &nbsp;&nbsp; <span class="checkbox">☐</span> כן —
        יש לבני בעיה בריאותית כרונית (כגון אסטמה, סוכרת נעורים, אפילפסיה, רגישות למזון, מחלה ממארת וכד'). פרט:
      </div>
      <div class="free-line"></div>

      <div class="row">
        <span class="checkbox"><%= (s.medications && s.medications !== 'לא ידוע') ? '☑' : '☐' %></span> לא &nbsp;&nbsp;
        <span class="checkbox"><%= (s.medications && s.medications !== 'לא ידוע') ? '☑' : '☐' %></span> כן —
        בני נוטל תרופה/ות באופן קבוע. פרט:
        <span class="free-text"><%= (s.medications && s.medications !== 'לא ידוע') ? s.medications : '' %></span>
      </div>

      <div class="row">
        <span class="checkbox"><%= (s.allergies && s.allergies !== 'לא ידוע') ? '☑' : '☐' %></span>
        בני סובל מרגישות לתרופות או למזון. פרט:
        <span class="free-text"><%= (s.allergies && s.allergies !== 'לא ידוע') ? s.allergies : '' %></span>
      </div>
      <div class="row sub-row">מצורף אישור רפואי המעיד על הבעיה הבריאותית/הרגישות, שניתן על ידי: <span class="free-text">&nbsp;</span> &nbsp; לתקופה: <span class="free-text">&nbsp;</span></div>

      <div class="row" style="margin-top:16px;">
        ☐ הריני מתחייב/ת להודיע למנהל/מלמד על כל שינוי או הגבלה זמניים או קבועים שיחולו במצב הבריאות של בני.
      </div>
      <div class="row">
        ☐ הריני מאשר/ת מתן מידע רלוונטי לצוות החינוכי ו/או לצוות הבריאות בכל הקשור למצב הבריאות של בני.
      </div>
      <div class="row">להלן מידע נוסף לגבי בריאות ילדי שברצוני ליידע את הת"ת על אודותיו:</div>
      <div class="free-line"></div>
      <div class="free-line"></div>
    </div>
  </div>

  <!-- ===== עמוד 3: הצהרת חיסונים + חתימה + אישור הורים ===== -->
  <div class="page">
    <div class="form-header">
      <img src="/images/logo-reports.jpg" alt="לוגו" />
      <div class="school-info">
        תלמוד תורה החדש (יסוד העולם)<br />
        כתובת: סוקולוב 5, בני ברק<br />
        טל: 03-6185020 | פקס: 03-6185030
      </div>
    </div>
    <div class="bsd">בס"ד</div>
    <div style="text-align:center; font-size:0.95em; color:#555; margin-bottom:10px;">
      המשך טופס הצהרת ההורים — <%= s.first_name %> <%= s.last_name %>
    </div>

    <div class="section-title">הצהרת חיסונים:</div>
    <div class="declaration">
      <div class="row">
        הריני מאשר/ת כי ידוע לי שבמסגרת שירותי הבריאות לתלמיד יקבל בני חיסון לפי תכנית החיסונים הנקבעת על ידי משרד הבריאות, וכן בדיקות שמיעה וראייה הנקבעות על ידי משרד הבריאות.
      </div>
      <div class="row">
        הריני מאשר/ת מתן חיסונים לבני לפי תכנית זו, אלא אם אודיע בכתב על התנגדותי להנהלת הת"ת. הריני מתחייב/ת להעביר את פנקס החיסונים כשידרש.
      </div>
      <div class="row">
        <span class="checkbox">☐</span> לא &nbsp;&nbsp; <span class="checkbox">☐</span> כן — לבני הייתה תגובה חריגה למתן חיסון בעבר.
      </div>
      <div class="row sub-row">אם כן, פרט לאיזה חיסון: <span class="free-text">&nbsp;</span></div>
      <div class="row sub-row">תיאור התגובה: <span class="free-line"></span></div>
    </div>

    <div class="sign-row">
      <div><div class="sign-line">התאריך</div></div>
      <div><div class="sign-line">שמות ההורים</div></div>
      <div><div class="sign-line">חתימת ההורים</div></div>
    </div>

    <div class="parent-approval">
      <div class="section-title" style="text-align:center;">אישור ההורים</div>
      <div class="declaration" style="margin-top:14px;">
        הריני <span class="free-text" style="min-width:180px;">&nbsp;</span>
        אביו/אימו של התלמיד
        <span class="free-text" style="min-width:180px;"><%= s.first_name %> <%= s.last_name %></span>
        נ"י מאשר/ת לבני לילך לבדו אל הת"ת וכן בשובו הביתה.
        <% if (s.walks_alone) { %>
          <div style="margin-top:10px; color:#555;">(סטטוס נוכחי במערכת: <strong><%= s.walks_alone %></strong>)</div>
        <% } %>
      </div>
      <table class="approval-table">
        <thead><tr><th>תאריך</th><th>שם ההורה</th><th>חתימה</th></tr></thead>
        <tbody><tr><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr></tbody>
      </table>
    </div>
  </div>
  <% }) %>
</body>
</html>
