<%- include('../partials/header', {title: 'רשימת כתות ייצוא לאקסל'}) %>

<div class="card">
  <h1>רשימת כתות - ייצוא לאקסל</h1>
  <p style="color:var(--muted);">בחר כיתה אחת או כמה כיתות, וסטטוס תלמידים (אופציונלי), ולחץ ייצוא.</p>

  <form method="GET" action="/reports/class-list/export">
    <div class="form-grid">
      <div class="form-group full">
        <label>כיתות (ניתן לבחור כמה - Ctrl+לחיצה)</label>
        <select name="class_id" multiple size="10" style="height:220px;">
          <% classes.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %><%= c.parallel ? ' ('+c.parallel+')' : '' %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>סטטוס תלמיד</label>
        <select name="status">
          <option value="">הכל</option>
          <% statuses.forEach(s => { %>
            <option value="<%= s.status %>"><%= s.status %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">📊 ייצוא לאקסל</button>
      <a href="/reports" class="btn secondary">חזרה לדוחות</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
