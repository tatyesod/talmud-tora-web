<%- include('../partials/header', {title: mode === 'new' ? 'אירוע חדש' : 'עריכת אירוע'}) %>

<div class="card">
  <h1><%= mode === 'new' ? 'הוספת אירוע חדש' : 'עריכת אירוע' %></h1>
  <form method="POST" action="<%= mode === 'new' ? '/events' : '/events/' + event.id + '?_method=PUT' %>">
    <div class="form-grid">
      <div class="form-group"><label>שם האירוע</label><input type="text" name="title" value="<%= event.title || '' %>" required /></div>
      <div class="form-group">
        <label>קטגוריה</label>
        <input type="text" name="category" list="cat-list" value="<%= event.category || '' %>" />
        <datalist id="cat-list">
          <option value="טיול"><option value="חג"><option value="אסיפת הורים"><option value="אירוע מיוחד">
        </datalist>
      </div>
      <div class="form-group"><label>תאריך התחלה</label><input type="date" name="event_date" value="<%= event.event_date || '' %>" required /></div>
      <div class="form-group"><label>תאריך סיום (אופציונלי)</label><input type="date" name="event_date_end" value="<%= event.event_date_end || '' %>" /></div>
      <div class="form-group">
        <label>כיתה (ריק = כלל המוסד)</label>
        <select name="class_id">
          <option value="">כלל המוסד</option>
          <% classes.forEach(c => { %>
            <option value="<%= c.id %>" <%= String(event.class_id) === String(c.id) ? 'selected' : '' %>><%= c.name %><%= c.parallel ? ' ('+c.parallel+')' : '' %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group"><label>מחיר (אופציונלי)</label><input type="number" step="0.01" name="price" value="<%= event.price != null ? event.price : '' %>" /></div>
      <div class="form-group">
        <label><input type="checkbox" name="requires_registration" <%= event.requires_registration ? 'checked' : '' %> style="width:auto; margin-left:6px;" /> דורש הרשמה</label>
      </div>
      <div class="form-group full"><label>תיאור</label><textarea name="description"><%= event.description || '' %></textarea></div>
    </div>
    <div class="actions" style="margin-top:14px;">
      <button type="submit" class="btn">שמירה</button>
      <a href="/events" class="btn secondary">ביטול</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
