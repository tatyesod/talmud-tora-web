<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>טופס בריאות - <%= student.full_name %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body onload="window.print()">
  <div class="print-doc">
    <h2>טופס בריאות</h2>
    <table style="width:100%;">
      <tr><td class="label">שם התלמיד</td><td><strong><%= student.full_name %></strong></td><td class="label">כיתה</td><td><%= student.class_name || '' %></td></tr>
      <tr><td class="label">ת.ז</td><td><%= student.id_number || '' %></td><td class="label">תאריך לידה</td><td><%= student.birth_date_civil_str || '' %> (<%= student.birth_date_hebrew_str || '' %>)</td></tr>
      <tr><td class="label">קופת חולים</td><td><%= student.health_fund || '' %></td><td class="label">הולך לבדו</td><td><%= student.walks_alone || '' %></td></tr>
      <tr><td class="label" colspan="1">אלרגיות</td><td colspan="3"><%= student.allergies || '' %></td></tr>
      <tr><td class="label" colspan="1">תרופות קבועות</td><td colspan="3"><%= student.medications || '' %></td></tr>
      <tr><td class="label" colspan="4">&nbsp;</td></tr>
      <tr><td class="label">שם האב</td><td><%= student.father_name || '' %></td><td class="label">נייד אב</td><td><%= student.father_mobile || '' %></td></tr>
      <tr><td class="label">שם האם</td><td><%= student.mother_name || '' %></td><td class="label">נייד אם</td><td><%= student.mother_mobile || '' %></td></tr>
      <tr><td class="label">טלפון בית</td><td colspan="3"><%= student.home_phone || '' %></td></tr>
      <tr><td class="label">כתובת</td><td colspan="3"><%= [student.street, student.house_number, student.apartment ? 'דירה '+student.apartment : '', student.city].filter(Boolean).join(', ') %></td></tr>
    </table>
    <p style="margin-top:40px; font-size:0.8em; color:var(--muted);">הופק ממערכת ניהול תלמוד תורה בתאריך <%= new Date().toLocaleDateString('he-IL') %></p>
  </div>
</body>
</html>
