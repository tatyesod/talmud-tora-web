<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>אנשי קשר לשעת חירום - <%= student.full_name %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body onload="window.print()">
  <div class="print-doc">
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #2c5f7c; padding-bottom:8px; margin-bottom:10px;">
      <h2 style="margin:0; border:none; padding:0;">אנשי קשר לשעת חירום</h2>
      <img src="/images/logo-reports.jpg" alt="לוגו" style="height:60px;" />
    </div>
    <table style="width:100%; margin-bottom:20px;">
      <tr><td class="label">שם התלמיד</td><td><strong><%= student.full_name %></strong></td><td class="label">כיתה</td><td><%= student.class_name || '' %></td></tr>
      <tr><td class="label">שם האב</td><td><%= student.father_name || '' %></td><td class="label">נייד אב</td><td><%= student.father_mobile || '' %></td></tr>
      <tr><td class="label">שם האם</td><td><%= student.mother_name || '' %></td><td class="label">נייד אם</td><td><%= student.mother_mobile || '' %></td></tr>
      <tr><td class="label">טלפון בית</td><td colspan="3"><%= student.home_phone || '' %></td></tr>
    </table>

    <% if (contacts.length === 0) { %>
      <p class="empty-state">לא הוזנו אנשי קשר לשעת חירום עבור משפחה זו</p>
    <% } else { %>
      <table>
        <thead>
          <tr><th>שם איש קשר</th><th>קרבה</th><th>טלפון 1</th><th>טלפון 2</th></tr>
        </thead>
        <tbody>
          <% contacts.forEach(c => { %>
            <tr>
              <td><%= c.contact_name || '' %></td>
              <td><%= c.relation || '' %></td>
              <td><%= c.phone1 || '' %></td>
              <td><%= c.phone2 || '' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <p style="margin-top:40px; font-size:0.8em; color:var(--muted);">הופק ממערכת ניהול תלמוד תורה בתאריך <%= new Date().toLocaleDateString('he-IL') %></p>
  </div>
</body>
</html>
