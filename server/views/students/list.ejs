<%- include('../partials/header', {title: 'רשימת תלמידים', wide: true}) %>

<div class="card">
  <h1>תלמידים <span style="font-size:0.6em; font-weight:400; color:var(--muted);">(<%= students.length %> נבחרים)</span></h1>
  <form class="searchbar auto-filter" method="GET" action="/students">
    <input type="text" name="q" placeholder="חיפוש לפי שם, ת.ז, טלפון, שם אב..." value="<%= q %>" autofocus dir="rtl" style="unicode-bidi: plaintext;" />
    <select name="class_id">
      <option value="">כל הכיתות</option>
      <% classes.forEach(c => { %>
        <option value="<%= c.id %>" <%= String(class_id) === String(c.id) ? 'selected' : '' %>><%= c.name %><%= c.parallel ? ' ('+c.parallel+')' : '' %></option>
      <% }) %>
    </select>
    <select name="cohort_id">
      <option value="">כל המחזורים</option>
      <% cohorts.forEach(c => { %>
        <option value="<%= c.id %>" <%= String(cohort_id) === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
      <% }) %>
    </select>
    <select name="status">
      <option value="" <%= status === '' ? 'selected' : '' %>>הצג הכל</option>
      <% statuses.forEach(s => { %>
        <option value="<%= s.status %>" <%= status === s.status ? 'selected' : '' %>><%= s.status %></option>
      <% }) %>
    </select>
    <select name="sector">
      <option value="">כל המגזרים</option>
      <option value="ליטאי" <%= sector === 'ליטאי' ? 'selected' : '' %>>ליטאי</option>
      <option value="ספרדי" <%= sector === 'ספרדי' ? 'selected' : '' %>>ספרדי</option>
      <option value="תמני" <%= sector === 'תמני' ? 'selected' : '' %>>תמני</option>
    </select>
    <select name="branch">
      <option value="">כל הסניפים</option>
      <option value="סוקולוב" <%= branch === 'סוקולוב' ? 'selected' : '' %>>סוקולוב</option>
      <option value="נפחא" <%= branch === 'נפחא' ? 'selected' : '' %>>נפחא</option>
      <option value="בן פתחיה" <%= branch === 'בן פתחיה' ? 'selected' : '' %>>בן פתחיה</option>
    </select>
    <button type="submit" class="btn">חיפוש</button>
    <a href="/students/new" class="btn secondary">+ תלמיד חדש</a>
    <a href="/students/duplicates" class="btn secondary">🔍 בדיקת כפילויות ת.ז</a>
    <input type="hidden" name="sort" value="<%= sort %>" />
    <input type="hidden" name="dir" value="<%= dir %>" />
  </form>

  <% if (students.length === 0) { %>
    <div class="empty-state">לא נמצאו תלמידים התואמים את החיפוש</div>
  <% } else { %>
    <form id="bulk-delete-form" method="POST" action="/students/bulk-delete"></form>
    <div id="bulk-toolbar" style="display:none; align-items:center; gap:10px; margin:10px 0; padding:10px 14px; background:#fdecea; border:1px solid #f5c6cb; border-radius:8px;">
      <span id="bulk-count-text" style="color:#a94442; font-weight:600;"></span>
      <button type="submit" form="bulk-delete-form" class="btn danger small" onclick="return confirmBulkDelete('תלמידים')">🗑️ מחק נבחרים</button>
      <button type="button" class="btn secondary small" onclick="clearBulkSelection()">בטל בחירה</button>
    </div>
    <div class="table-scroll-wrap"><table>
      <thead>
        <tr>
          <th><input type="checkbox" id="select-all-rows" /></th>
          <th><a href="<%= sortUrl('last_name') %>">שם משפחה<%= sortIndicator('last_name') %></a></th>
          <th><a href="<%= sortUrl('first_name') %>">שם פרטי<%= sortIndicator('first_name') %></a></th>
          <th><a href="<%= sortUrl('nickname') %>">כינוי<%= sortIndicator('nickname') %></a></th>
          <th><a href="<%= sortUrl('class_name') %>">כיתה<%= sortIndicator('class_name') %></a></th>
          <th>סניף</th>
          <th><a href="<%= sortUrl('id_number') %>">ת.ז<%= sortIndicator('id_number') %></a></th>
          <th>מגזר</th>
          <th>שם האב</th>
          <th>נייד אב</th>
          <th>שם האם</th>
          <th>נייד אם</th>
          <th><a href="<%= sortUrl('home_phone') %>">טלפון בית<%= sortIndicator('home_phone') %></a></th>
          <th>כתובת</th>
          <th><a href="<%= sortUrl('status') %>">סטטוס<%= sortIndicator('status') %></a></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% students.forEach(s => { %>
          <tr>
            <td><input type="checkbox" class="row-check" name="ids" value="<%= s.id %>" form="bulk-delete-form" /></td>
            <td><a href="/students/<%= s.id %>"><%= s.last_name || s.family_last_name || '' %></a></td>
            <td><%= s.first_name || '' %></td>
            <td><%= s.nickname || '' %></td>
            <td><%= (s.class_name || '') + (s.class_parallel ? ' ' + s.class_parallel : '') %></td>
            <td><%= s.branch || '' %></td>
            <td><%= s.id_number || '' %></td>
            <td><%= s.sector || '' %></td>
            <td><%= s.father_name || '' %></td>
            <td><%- phoneLink(s.father_mobile) %></td>
            <td><%= s.mother_name || '' %></td>
            <td><%- phoneLink(s.mother_mobile) %></td>
            <td><%- phoneLink(s.home_phone) %></td>
            <td><%= [s.street, s.house_number].filter(Boolean).join(' ') || s.city || '' %></td>
            <td>
              <span class="badge <%= s.status === 'ארכיון' ? 'archive' : (s.status === 'לא פעיל' ? 'archive' : '') %>"><%= s.status || '' %></span>
            </td>
            <td><a href="/students/<%= s.id %>" class="btn small secondary">צפייה</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table></div>
    <p style="color:var(--muted); margin-top:10px;">סה"כ <%= students.length %> תלמידים</p>
  <% } %>
</div>

<script src="/js/bulk-select.js"></script>
<script>initBulkSelect('select-all-rows', 'תלמידים');</script>

<%- include('../partials/footer') %>
