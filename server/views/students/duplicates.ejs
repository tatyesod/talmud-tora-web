<%- include('../partials/header', {title: 'כפילויות ת.ז'}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>🔍 בדיקת כפילויות ת.ז קיימות</h1>
    <a href="/students" class="btn secondary">← חזרה לרשימת תלמידים</a>
  </div>

  <% if (groups.length === 0) { %>
    <div style="background:#eef6ee; border:1px solid #bcd9bc; border-radius:8px; padding:12px 16px; margin-top:14px; color:#2d7a2d;">
      ✅ לא נמצאו כפילויות ת.ז במערכת - כל מספרי הזהות המוזנים ייחודיים.
    </div>
  <% } else { %>
    <div style="background:#fdecea; border:1px solid #f5c6cb; border-radius:8px; padding:12px 16px; margin:14px 0; color:#a94442;">
      ⚠️ נמצאו <%= groups.length %> מספרי ת.ז שמופיעים אצל יותר מתלמיד אחד. כדאי לבדוק כל קבוצה - יכול להיות שזה אותו תלמיד שהוזן פעמיים בטעות, טעות הקלדה, או שני אחים ששיתפו בטעות אותו מספר.
    </div>

    <% groups.forEach(g => { %>
      <div style="border:1px solid var(--border); border-radius:8px; padding:12px 16px; margin-bottom:12px;">
        <div style="font-weight:700; margin-bottom:8px;">ת.ז: <%= g.idNumber %> (<%= g.students.length %> תלמידים)</div>
        <table>
          <thead><tr><th>שם</th><th>משפחה</th><th>כיתה</th><th>סטטוס</th><th></th></tr></thead>
          <tbody>
            <% g.students.forEach(s => { %>
              <tr>
                <td><%= s.first_name %> <%= s.last_name %></td>
                <td><%= s.family_last_name || '' %></td>
                <td><%= s.class_name ? s.class_name + (s.class_parallel ? ' ('+s.class_parallel+')' : '') : '—' %></td>
                <td><span class="badge <%= s.status !== 'פעיל' ? 'archive' : '' %>"><%= s.status || '' %></span></td>
                <td><a href="/students/<%= s.id %>" class="btn small secondary" target="_blank">פתח כרטיס</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include('../partials/footer') %>
