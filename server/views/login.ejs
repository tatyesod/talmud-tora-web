<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>התחברות - תלמוד תורה</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '' %>" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/images/icon-192.png" />
  <link rel="icon" href="/images/icon-192.png" />
  <meta name="theme-color" content="#0d1b2e" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="ת״ת החדש" />
</head>
<body>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
  <div class="login-box card">
    <h2>📖 כניסה למערכת</h2>
    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
    <form method="POST" action="/login">
      <div class="form-group">
        <label>שם משתמש</label>
        <input type="text" name="username" required autofocus />
      </div>
      <div class="form-group" style="margin-top:10px;">
        <label>סיסמה</label>
        <input type="password" name="password" required />
      </div>
      <button type="submit" class="btn" style="margin-top:16px; width:100%;">כניסה</button>
    </form>
  </div>
</body>
</html>
