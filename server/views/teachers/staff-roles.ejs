<%- include('../partials/header', {title: 'תפקידי צוות נוספים'}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>👔 תפקידי צוות נוספים</h1>
    <a href="/teachers" class="btn secondary">← חזרה למלמדים ועובדים</a>
  </div>

  <p style="color:var(--muted); font-size:0.9em;">
    כאן מגדירים תפקידים לצוות שאינו בהוראה (מזכירות, תחזוקה, ניקיון, שילוב וכו') - עם אפשרות לשייך כל תפקיד לסניף
    ספציפי (או להשאיר "כל הסניפים" לתפקיד כללי כמו מנהל הת"ת). לאחר שהתפקיד מוגדר כאן, אפשר לסמן אותו בכרטיס של
    כל עובד, וזה יילקח בחשבון גם בסינון לפי סניף במסך "מלמדים ועובדים".
  </p>

  <h3 style="margin-top:20px;">➕ הוספת תפקיד</h3>
  <form method="POST" action="/teachers/staff-roles" style="display:flex; flex-wrap:wrap; gap:14px; align-items:end;">
    <div class="form-group">
      <label>שם התפקיד</label>
      <input type="text" name="name" placeholder="לדוגמה: רכז בטיחות" required style="min-width:200px;" />
    </div>
    <div class="form-group">
      <label>סניף</label>
      <select name="branch">
        <option value="">כל הסניפים (תפקיד כללי)</option>
        <% branches.forEach(b => { %>
          <option value="<%= b %>"><%= b %></option>
        <% }) %>
      </select>
    </div>
    <button type="submit" class="btn">💾 הוסף תפקיד</button>
  </form>

  <h3 style="margin-top:24px;">רשימת תפקידים</h3>
  <table>
    <thead><tr><th>תפקיד</th><th>סניף</th><th>מספר עובדים משויכים</th><th></th></tr></thead>
    <tbody>
      <% roles.forEach(r => { %>
        <tr>
          <td><%= r.name %></td>
          <td><%= r.branch || 'כל הסניפים' %></td>
          <td><%= r.assignedCount %></td>
          <td>
            <form method="POST" action="/teachers/staff-roles/<%= r.id %>?_method=DELETE"
                  onsubmit="return confirm('<%= r.assignedCount > 0 ? ("שים לב - " + r.assignedCount + " עובדים משויכים לתפקיד הזה, השיוך שלהם יוסר. ") : "" %>למחוק את התפקיד?');" style="display:inline">
              <button type="submit" class="btn small danger">מחק</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
