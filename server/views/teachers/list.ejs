<%- include('../partials/header', {title: 'מלמדים ועובדים', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>מלמדים ועובדים</h1>
    <div style="display:flex; gap:10px;">
      <a href="/teachers/staffing-map" class="btn secondary">👥 מצבת מלמדים</a>
      <a href="/teachers/monthly-reports" class="btn secondary">📊 מעקב דוחות חודשיים</a>
    </div>
  </div>
  <p style="color:var(--muted); font-size:0.9em; margin-top:-8px;">
    סך הכל ילדים בבית (לפי הרשימה המוצגת): <strong style="color:var(--primary-dark);"><%= totalChildren %></strong>
    — שימושי לחישוב תקציב חלוקת מתנות
  </p>
  <form class="searchbar auto-filter" method="GET" action="/teachers">
    <input type="text" name="q" placeholder="חיפוש לפי שם, ת.ז, נייד..." value="<%= q %>" />
    <select name="status">
      <option value="" <%- status === '' ? 'selected' : '' %>>הצג הכל</option>
      <% statuses.forEach(s => { %>
        <option value="<%= s.status %>" <%= status === s.status ? 'selected' : '' %>><%= s.status %></option>
      <% }) %>
    </select>
    <button type="submit" class="btn">חיפוש</button>
    <a href="/teachers/new" class="btn secondary">+ מלמד/עובד חדש</a>
    <input type="hidden" name="sort" value="<%= sort %>" />
    <input type="hidden" name="dir" value="<%= dir %>" />
  </form>

  <% if (teachers.length === 0) { %>
    <div class="empty-state">לא נמצאו מלמדים</div>
  <% } else { %>
    <div class="table-scroll-wrap"><table>
      <thead><tr>
        <th><a href="<%= sortUrl('last_name') %>">שם משפחה<%= sortIndicator('last_name') %></a></th>
        <th><a href="<%= sortUrl('first_name') %>">שם פרטי<%= sortIndicator('first_name') %></a></th>
        <th>כתובת</th>
        <th>שיבוץ בוקר</th>
        <th>שיבוץ אחה"צ</th>
        <th><a href="<%= sortUrl('mobile') %>">טלפון<%= sortIndicator('mobile') %></a></th>
        <th><a href="<%= sortUrl('children_count') %>">מס' ילדים<%= sortIndicator('children_count') %></a></th>
        <th><a href="<%= sortUrl('status') %>">סטטוס<%= sortIndicator('status') %></a></th>
        <th></th>
      </tr></thead>
      <tbody>
        <% teachers.forEach(t => {
          const address = [t.street, t.house_number].filter(Boolean).join(' ') + (t.city ? (', ' + t.city) : '');
        %>
          <tr>
            <td><a href="/teachers/<%= t.id %>"><%= t.last_name || '' %></a></td>
            <td><%= t.first_name || '' %></td>
            <td style="font-size:0.88em;"><%= address.trim().replace(/^,\s*/, '') || '' %></td>
            <td style="font-size:0.85em;"><%= t.morning_classes || '' %></td>
            <td style="font-size:0.85em;"><%= t.afternoon_classes || '' %></td>
            <td><%- phoneLink(t.mobile || t.home_phone) %></td>
            <td><%= t.children_count_display != null ? t.children_count_display : '' %></td>
            <td><span class="badge <%= t.status !== 'פעיל' ? 'archive' : '' %>"><%= t.status || '' %></span></td>
            <td><a href="/teachers/<%= t.id %>" class="btn small secondary">צפייה</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table></div>
    <p style="color:var(--muted); margin-top:10px;">סה"כ <%= teachers.length %> מלמדים</p>
  <% } %>
</div>

<%- include('../partials/footer') %>
