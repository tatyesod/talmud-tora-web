<%- include('../partials/header', {title: 'מצבת מלמדים', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>👥 מצבת מלמדים</h1>
    <a href="/teachers" class="btn secondary">← חזרה למלמדים</a>
  </div>

  <p style="color:var(--muted); font-size:0.88em;">
    מפה חיה של שיבוץ המלמדים, לפי סניף. <strong>לחיצה על תא ובחירת מלמד משבצת אותו מיד</strong> — זה מעדכן אוטומטית
    גם את כרטיס הכיתה וגם את כרטיס המלמד (אותו נתון בדיוק). תאים אדומים = חוסר אמיתי שצריך לגייס עבורו. תאים אפורים
    (—) = לא רלוונטי לסוג כיתה זה (למשל אין אחה"צ במכינה א', ואין עוזר בכיתות א'-ח').
  </p>

  <% if (saved) { %>
    <div style="background:#e8f5e9; border:1px solid #a5d6a7; color:#2e7d32; border-radius:8px; padding:8px 14px; margin-bottom:12px; font-size:0.9em;">✅ השיבוץ עודכן.</div>
  <% } %>

  <div style="display:flex; gap:10px; flex-wrap:wrap; margin:14px 0;">
    <div style="background:<%= missingMorning > 0 ? '#fdecea' : '#eef6ee' %>; border:1px solid <%= missingMorning > 0 ? '#f0b8b0' : '#bcd9bc' %>; border-radius:8px; padding:8px 16px; min-width:130px;">
      <div style="font-size:1.2em; font-weight:800; color:<%= missingMorning > 0 ? '#a94442' : '#2d7a4f' %>;"><%= missingMorning %></div>
      <div style="color:var(--muted); font-size:0.8em;">חסרי בוקר</div>
    </div>
    <div style="background:<%= missingAfternoon > 0 ? '#fdecea' : '#eef6ee' %>; border:1px solid <%= missingAfternoon > 0 ? '#f0b8b0' : '#bcd9bc' %>; border-radius:8px; padding:8px 16px; min-width:130px;">
      <div style="font-size:1.2em; font-weight:800; color:<%= missingAfternoon > 0 ? '#a94442' : '#2d7a4f' %>;"><%= missingAfternoon %></div>
      <div style="color:var(--muted); font-size:0.8em;">חסרי אחה"צ</div>
    </div>
    <div style="background:<%= missingHelper > 0 ? '#fdecea' : '#eef6ee' %>; border:1px solid <%= missingHelper > 0 ? '#f0b8b0' : '#bcd9bc' %>; border-radius:8px; padding:8px 16px; min-width:130px;">
      <div style="font-size:1.2em; font-weight:800; color:<%= missingHelper > 0 ? '#a94442' : '#2d7a4f' %>;"><%= missingHelper %></div>
      <div style="color:var(--muted); font-size:0.8em;">חסרי עוזר</div>
    </div>
  </div>

  <% branches.forEach(branch => { %>
    <h3 style="border-bottom:2px solid #2c5f7c; padding-bottom:4px; margin-top:20px; font-size:1.05em;"><%= branch || 'ללא סניף' %></h3>
    <table class="staffing-table">
      <thead><tr><th>כיתה</th><th>בוקר</th><th>אחה"צ</th><th>עוזר</th></tr></thead>
      <tbody>
        <% rows.filter(r => r.branch === branch).forEach(r => { %>
          <tr>
            <td class="cls-name"><%= r.class_full_name %></td>

            <td class="<%= r.morning ? 'filled' : 'gap' %>">
              <form method="POST" action="/teachers/staffing-map/assign">
                <input type="hidden" name="class_id" value="<%= r.class_id %>" />
                <input type="hidden" name="role" value="בוקר" />
                <select name="teacher_id" onchange="this.form.submit()">
                  <option value="">— חסר —</option>
                  <% allTeachers.forEach(t => { %>
                    <option value="<%= t.id %>" <%= r.morning && r.morning.teacher_id === t.id ? 'selected' : '' %>><%= t.last_name %> <%= t.first_name %></option>
                  <% }) %>
                </select>
              </form>
            </td>

            <% if (r.afternoonStatus === 'na') { %>
              <td class="neutral">—</td>
            <% } else if (r.afternoonStatus === 'grace' && !r.afternoon) { %>
              <td class="grace">ישובץ עד חנוכה</td>
            <% } else { %>
              <td class="<%= r.afternoon ? 'filled' : 'gap' %>">
                <form method="POST" action="/teachers/staffing-map/assign">
                  <input type="hidden" name="class_id" value="<%= r.class_id %>" />
                  <input type="hidden" name="role" value='אחה"צ' />
                  <select name="teacher_id" onchange="this.form.submit()">
                    <option value="">— חסר —</option>
                    <% allTeachers.forEach(t => { %>
                      <option value="<%= t.id %>" <%= r.afternoon && r.afternoon.teacher_id === t.id ? 'selected' : '' %>><%= t.last_name %> <%= t.first_name %></option>
                    <% }) %>
                  </select>
                </form>
              </td>
            <% } %>

            <% if (r.helperStatus === 'na') { %>
              <td class="neutral">—</td>
            <% } else { %>
              <td class="<%= r.helper ? 'filled' : 'gap' %>">
                <form method="POST" action="/teachers/staffing-map/assign">
                  <input type="hidden" name="class_id" value="<%= r.class_id %>" />
                  <input type="hidden" name="role" value="עוזר" />
                  <select name="teacher_id" onchange="this.form.submit()">
                    <option value="">— חסר —</option>
                    <% allTeachers.forEach(t => { %>
                      <option value="<%= t.id %>" <%= r.helper && r.helper.teacher_id === t.id ? 'selected' : '' %>><%= t.last_name %> <%= t.first_name %></option>
                    <% }) %>
                  </select>
                </form>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% }) %>
</div>

<style>
  .staffing-table { width: auto; max-width: 620px; border-collapse: collapse; font-size: 0.82em; }
  .staffing-table th, .staffing-table td { padding: 3px 6px; border: 1px solid #e0e0e0; text-align: center; }
  .staffing-table .cls-name { text-align: right; font-weight: 600; white-space: nowrap; background: #f7f9fb; }
  .staffing-table td.filled { background: #eef6ee; }
  .staffing-table td.gap { background: #fdecea; }
  .staffing-table td.neutral { color: #aaa; background: #fafafa; }
  .staffing-table td.grace { background: #fff8e1; color: #8a6d00; font-size: 0.85em; white-space: nowrap; }
  .staffing-table select { width: 105px; font-size: 0.95em; border: none; background: transparent; text-align: center; }
  .staffing-table td.gap select { color: #a94442; font-weight: 700; }
  .staffing-table td.filled select { color: #2d7a4f; }
</style>

<%- include('../partials/footer') %>
