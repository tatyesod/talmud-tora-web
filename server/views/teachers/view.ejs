<%- include('../partials/header', {title: (teacher.first_name||'')+' '+(teacher.last_name||'')}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:10px;">
    <h1><%= teacher.first_name %> <%= teacher.last_name %> <span class="badge <%= teacher.status !== 'פעיל' ? 'archive' : '' %>"><%= teacher.status || '' %></span></h1>
    <div class="actions">
      <a href="/teachers/<%= teacher.id %>/edit" class="btn">עריכה</a>
      <form method="POST" action="/teachers/<%= teacher.id %>?_method=DELETE" onsubmit="return confirm('האם למחוק?');" style="display:inline">
        <button type="submit" class="btn danger">מחיקה</button>
      </form>
      <a href="/teachers" class="btn secondary">חזרה לרשימה</a>
    </div>
  </div>
</div>

<div class="card">
  <h3>פרטים אישיים</h3>
  <table>
    <tr>
      <th>שם משפחה</th><td><strong><%= teacher.last_name || '' %></strong></td>
      <th>שם פרטי</th><td><strong><%= teacher.first_name || '' %></strong></td>
    </tr>
    <tr>
      <th>מספר זהות</th><td><%= teacher.id_number || '' %></td>
      <th>מין</th><td><%= teacher.gender || '' %></td>
    </tr>
    <tr>
      <th>תאריך לידה</th>
      <td>
        <%= teacher.birth_date_civil_str || '' %>
        <% if (teacher.birth_date_hebrew_str) { %>
          <span style="color:var(--muted); font-size:0.9em;">(<%= teacher.birth_date_hebrew_str %>)</span>
        <% } %>
        <% if (teacher.age != null) { %>
          &nbsp;<span style="background:#e8f0f7; color:#2c5f7c; border-radius:10px; padding:2px 8px; font-size:0.85em; font-weight:700;">גיל: <%= teacher.age %></span>
        <% } %>
      </td>
      <th>קופת חולים</th><td><%= teacher.health_fund || '' %></td>
    </tr>
    <tr>
      <th>נייד</th><td><%- phoneLink(teacher.mobile) %></td>
      <th>טלפון בית</th><td><%- phoneLink(teacher.home_phone) %></td>
    </tr>
    <tr>
      <th>כתובת דוא"ל</th><td><%- emailLink(teacher.email) %></td>
      <th>סניף</th><td><%= teacher.branch || '' %></td>
    </tr>
    <tr>
      <th>כתובת</th>
      <td colspan="3"><%= [teacher.street, teacher.house_number, teacher.city].filter(Boolean).join(' ') %></td>
    </tr>
    <tr>
      <th>מס' ילדים</th><td><%= teacher.children_count_total != null ? teacher.children_count_total : '' %></td>
      <th>סטטוס</th><td><span class="badge <%= teacher.status !== 'פעיל' ? 'archive' : '' %>"><%= teacher.status || '' %></span></td>
    </tr>
    <tr><th>הערות</th><td colspan="3"><%= teacher.notes || '' %></td></tr>
  </table>
</div>

<div class="card">
  <h3>פרטי בן/בת הזוג</h3>
  <% const hasSpouse = teacher.spouse_first_name || teacher.spouse_last_name || teacher.id_number_spouse; %>
  <% if (!hasSpouse) { %>
    <p class="empty-state">אין פרטי בן/בת זוג</p>
  <% } else { %>
  <table>
    <tr>
      <th>שם פרטי</th><td><%= teacher.spouse_first_name || '' %></td>
      <th>שם משפחה</th><td><%= teacher.spouse_last_name || '' %></td>
    </tr>
    <tr>
      <th>מספר זהות</th><td><%= teacher.id_number_spouse || '' %></td>
      <th>תאריך לידה</th>
      <td>
        <%= teacher.spouse_birth_date_str || '' %>
        <% if (teacher.spouse_birth_date_hebrew_str) { %>
          <span style="color:var(--muted); font-size:0.9em;">(<%= teacher.spouse_birth_date_hebrew_str %>)</span>
        <% } %>
        <% if (teacher.spouse_age != null) { %>
          &nbsp;<span style="background:#e8f0f7; color:#2c5f7c; border-radius:10px; padding:2px 8px; font-size:0.85em; font-weight:700;">גיל: <%= teacher.spouse_age %></span>
        <% } %>
      </td>
    </tr>
  </table>
  <% } %>
</div>

<div class="card">
  <h3>כיתות בהוראה</h3>
  <% if (classes.length === 0) { %>
    <p class="empty-state">לא משובץ לכיתות</p>
  <% } else { %>
    <table>
      <% classes.forEach(c => { %>
        <tr><td><a href="/classes/<%= c.id %>"><%= c.name %><%= c.parallel ? ' ('+c.parallel+')' : '' %></a></td><td><%= c.role || '' %></td></tr>
      <% }) %>
    </table>
  <% } %>
</div>

<div class="card">
  <h3>נוכחות וחיסורים</h3>
  <% if (attendanceSummary.length > 0) { %>
    <p style="color:var(--muted); font-size:0.9em;">
      <% attendanceSummary.forEach(s => { %><strong><%= s.status %>:</strong> <%= s.c %> &nbsp;&nbsp; <% }) %>
    </p>
  <% } %>
  <% if (attendance.length === 0) { %>
    <p class="empty-state">אין רישומי נוכחות</p>
  <% } else { %>
    <table>
      <thead><tr><th>תאריך</th><th>סטטוס</th><th>הערות</th><th></th></tr></thead>
      <tbody>
        <% attendance.forEach(a => { %>
          <tr>
            <td><%= a.att_date_str %></td>
            <td><%= a.status %></td>
            <td><%= a.notes || '' %></td>
            <td>
              <form method="POST" action="/teachers/<%= teacher.id %>/attendance/<%= a.id %>?_method=DELETE" style="display:inline">
                <button type="submit" class="btn small danger">מחק</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  <form method="POST" action="/teachers/<%= teacher.id %>/attendance" class="form-grid" style="margin-top:14px;">
    <div class="form-group"><label>תאריך</label><input type="date" name="att_date" /></div>
    <div class="form-group">
      <label>סטטוס</label>
      <select name="status" required>
        <option value="נוכח">נוכח</option>
        <option value="נעדר">נעדר</option>
        <option value="חופשה">חופשה</option>
        <option value="מחלה">מחלה</option>
      </select>
    </div>
    <div class="form-group full"><label>הערות</label><input type="text" name="notes" /></div>
    <div class="form-group full"><button type="submit" class="btn small">+ הוסף רישום</button></div>
  </form>
</div>

<div class="card">
  <h3>תיק עובד</h3>
  <% if (file.length === 0) { %>
    <p class="empty-state">אין רשומות בתיק העובד</p>
  <% } else { %>
    <table>
      <thead><tr><th>תאריך</th><th>קטגוריה</th><th>פירוט</th><th>קובץ מצורף</th><th></th></tr></thead>
      <tbody>
        <% file.forEach(f => { %>
          <tr>
            <td><%= f.entry_date_str %></td>
            <td><%= f.category || '' %></td>
            <td><%= f.notes || '' %></td>
            <td>
              <% if (f.file_path) { %>
                <a href="<%= f.file_path %>" target="_blank" class="btn small secondary" style="font-size:0.8em;">
                  📎 <%= f.file_name || 'פתח קובץ' %>
                </a>
              <% } else { %>
                <span style="color:var(--muted); font-size:0.85em;">—</span>
              <% } %>
            </td>
            <td>
              <form method="POST" action="/teachers/<%= teacher.id %>/file/<%= f.id %>?_method=DELETE"
                    onsubmit="return confirm('למחוק רשומה זו?');" style="display:inline">
                <button type="submit" class="btn small danger">מחק</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <form method="POST" action="/teachers/<%= teacher.id %>/file"
        enctype="multipart/form-data" class="form-grid" style="margin-top:16px;">
    <div class="form-group"><label>תאריך</label><input type="date" name="entry_date" /></div>
    <div class="form-group">
      <label>קטגוריה</label>
      <select name="category">
        <option value="חוזה">חוזה</option>
        <option value="תעודה">תעודה</option>
        <option value="הערכה">הערכה</option>
        <option value="מסמך רפואי">מסמך רפואי</option>
        <option value="אישור">אישור</option>
        <option value="אחר">אחר</option>
      </select>
    </div>
    <div class="form-group full"><label>פירוט / הערות</label><textarea name="notes" rows="2"></textarea></div>
    <div class="form-group full">
      <label>קובץ מצורף (PDF, Word, תמונה — עד 10MB)</label>
      <input type="file" name="attachment"
             accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.xls,.xlsx"
             style="padding:6px; border:1px solid var(--border); border-radius:8px; width:100%;" />
    </div>
    <div class="form-group full">
      <button type="submit" class="btn small">📎 הוסף לתיק העובד</button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
