<%- include('../partials/header', {title: 'מעקב דוחות חודשיים', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>מעקב הגשת דוחות חודשיים - <%= monthDisplay %> <%= year %></h1>
    <a href="/teachers" class="btn small secondary">← חזרה למלמדים</a>
  </div>

  <form method="GET" action="/teachers/monthly-reports" style="margin:14px 0; display:flex; gap:14px; align-items:center;">
    <div>
      <label>תקופת הגשה: </label>
      <select name="month" onchange="this.form.submit()">
        <% monthOptions.forEach(m => { %>
          <option value="<%= m %>" <%= m === month ? 'selected' : '' %>><%= m %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label>שנה"ל: </label>
      <select name="year" onchange="this.form.submit()">
        <% yearOptions.forEach(y => { %>
          <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
        <% }) %>
      </select>
    </div>
  </form>

  <div class="summary-panel" style="display:inline-block; background:<%= submittedCount === total ? '#e8f5e9' : '#fff3e0' %>;">
    <div class="summary-num"><%= submittedCount %> / <%= total %></div>
    <div class="summary-text">מלמדים שהגישו דוח לחודש זה</div>
  </div>

  <table style="margin-top:16px;">
    <thead><tr><th>מלמד</th><th>סטטוס</th><th>תאריך הגשה</th><th>קובץ</th></tr></thead>
    <tbody>
      <% rows.forEach(r => { %>
        <tr>
          <td><a href="/teachers/<%= r.teacher_id %>"><%= r.teacher_name %></a></td>
          <td>
            <% if (r.submitted) { %><span style="color:#2e7d32;">✅ הוגש</span>
            <% } else { %><span style="color:#a94442;">❌ לא הוגש</span>
            <% } %>
          </td>
          <td><%= r.submitted_date_str %></td>
          <td>
            <% if (r.file_path) { %>
              <a href="<%= r.file_path %>" target="_blank" class="btn small secondary">📎 <%= r.file_name || 'פתיחה' %></a>
            <% } else if (!r.submitted) { %>
              <a href="/teachers/<%= r.teacher_id %>" class="btn small secondary">+ רישום הגשה</a>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
