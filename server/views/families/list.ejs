<%- include('../partials/header', {title: 'משפחות', wide: true}) %>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
    <h1>משפחות</h1>
    <a href="/families/donations" class="btn secondary">💝 ניהול תרומות חודשיות</a>
    <a href="/families/import-external" class="btn secondary">📥 ייבוא תרומות/מיילים מסליקה</a>
  </div>
  <form class="searchbar auto-filter" method="GET" action="/families">
    <input type="text" name="q" placeholder="חיפוש לפי שם משפחה, שם אב, טלפון..." value="<%= q %>" autofocus />
    <select name="sector">
      <option value="">כל המגזרים</option>
      <option value="ליטאי" <%= sector === 'ליטאי' ? 'selected' : '' %>>ליטאי</option>
      <option value="ספרדי" <%= sector === 'ספרדי' ? 'selected' : '' %>>ספרדי</option>
      <option value="תמני" <%= sector === 'תמני' ? 'selected' : '' %>>תמני</option>
    </select>
    <select name="branch">
      <option value="">כל הסניפים</option>
      <option value="סוקולוב" <%= branch === 'סוקולוב' ? 'selected' : '' %>>סוקולוב</option>
      <option value="נפחא" <%= branch === 'נפחא' ? 'selected' : '' %>>נפחא</option>
      <option value="בן פתחיה" <%= branch === 'בן פתחיה' ? 'selected' : '' %>>בן פתחיה</option>
    </select>
    <select name="status">
      <option value="" <%- status === '' ? 'selected' : '' %>>הצג הכל</option>
      <option value="פעיל" <%= status === 'פעיל' ? 'selected' : '' %>>פעיל</option>
      <option value="לא פעיל" <%= status === 'לא פעיל' ? 'selected' : '' %>>לא פעיל</option>
      <option value="ארכיון" <%= status === 'ארכיון' ? 'selected' : '' %>>ארכיון</option>
    </select>
    <button type="submit" class="btn">חיפוש</button>
    <input type="hidden" name="sort" value="<%= sort %>" />
    <input type="hidden" name="dir" value="<%= dir %>" />
  </form>

  <% if (families.length === 0) { %>
    <div class="empty-state">לא נמצאו משפחות</div>
  <% } else { %>
    <form id="bulk-delete-form" method="POST" action="/families/bulk-delete"></form>
    <div id="bulk-toolbar" style="display:none; align-items:center; gap:10px; margin:10px 0; padding:10px 14px; background:#fdecea; border:1px solid #f5c6cb; border-radius:8px;">
      <span id="bulk-count-text" style="color:#a94442; font-weight:600;"></span>
      <span style="color:#a94442; font-size:0.85em;">(⚠️ ימחקו גם כל התלמידים ששייכים למשפחות שנבחרו, וכל הנתונים שלהם)</span>
      <button type="submit" form="bulk-delete-form" class="btn danger small" onclick="return confirmBulkDelete('משפחות, כולל כל התלמידים והנתונים שלהם')">🗑️ מחק נבחרות</button>
      <button type="button" class="btn secondary small" onclick="clearBulkSelection()">בטל בחירה</button>
    </div>
    <div class="table-scroll-wrap"><table>
      <thead><tr>
        <th><input type="checkbox" id="select-all-rows" /></th>
        <th><a href="<%= sortUrl('last_name') %>">שם משפחה<%= sortIndicator('last_name') %></a></th>
        <th><a href="<%= sortUrl('father_name') %>">שם האב<%= sortIndicator('father_name') %></a></th>
        <th><a href="<%= sortUrl('mother_name') %>">שם האם<%= sortIndicator('mother_name') %></a></th>
        <th><a href="<%= sortUrl('sector') %>">מגזר<%= sortIndicator('sector') %></a></th>
        <th><a href="<%= sortUrl('home_phone') %>">טלפון בית<%= sortIndicator('home_phone') %></a></th>
        <th>נייד אב</th>
        <th>נייד אם</th>
        <th>כתובת</th>
        <th><a href="<%= sortUrl('city') %>">עיר<%= sortIndicator('city') %></a></th>
        <th>שכ"ל כולל</th>
        <th></th>
      </tr></thead>
      <tbody>
        <% families.forEach(f => { %>
          <tr>
            <td><input type="checkbox" class="row-check" name="ids" value="<%= f.id %>" form="bulk-delete-form" /></td>
            <td class="nowrap-cell"><a href="/families/<%= f.id %>"><%= f.last_name || '' %></a></td>
            <td class="nowrap-cell"><%= f.father_name || '' %></td>
            <td class="nowrap-cell"><%= f.mother_name || '' %></td>
            <td><%= f.sector || '' %></td>
            <td><%- phoneLink(f.home_phone) %></td>
            <td><%- phoneLink(f.father_mobile) %></td>
            <td><%- phoneLink(f.mother_mobile) %></td>
            <td class="nowrap-cell"><%= [f.street, f.house_number].filter(Boolean).join(' ') %></td>
            <td class="nowrap-cell"><%= f.city || '' %></td>
            <td class="nowrap-cell"><strong><%= f.tuitionTotal.toLocaleString() %> ₪</strong></td>
            <td class="nowrap-cell">
              <a href="/families/<%= f.id %>" class="btn small secondary">צפייה</a>
              <a href="/families/<%= f.id %>/edit" class="btn small secondary">עריכה</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table></div>
    <p style="color:var(--muted); margin-top:10px;">סה"כ <%= families.length %> משפחות</p>
  <% } %>
</div>

<script src="/js/bulk-select.js"></script>
<script>initBulkSelect('select-all-rows', 'משפחות');</script>

<%- include('../partials/footer') %>
