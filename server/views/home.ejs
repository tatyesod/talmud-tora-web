<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>תלמוד תורה החדש - מערכת ניהול</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/home.css" />
</head>
<body class="home-body">

  <div class="home-bg">
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>
    <div class="orb orb3"></div>
    <div class="stars"></div>
  </div>

  <div class="home-topbar">
    <span class="bsd">בס"ד</span>
    <a href="/year" class="year-pill">שנת לימודים: <strong><%= currentYear %></strong></a>
    <a href="/messages" class="year-pill">💬 הודעות<% if (unreadCount > 0) { %> <span class="unread-badge"><%= unreadCount %></span><% } %></a>
    <% if (isAdmin) { %><a href="/users" class="year-pill">👥 משתמשים</a><% } %>
    <a href="/profile" class="year-pill">👤 <%= user %></a>
    <form action="/logout" method="POST">
      <button type="submit" class="btn-logout">יציאה</button>
    </form>
  </div>

  <main class="home-main">
    <div class="logo-wrap">
      <div class="logo-glow"></div>
      <img src="/images/logo.png" alt="תלמוד תורה החדש" class="home-logo" />
    </div>

    <h1 class="home-title">תלמוד תורה החדש</h1>
    <p class="home-subtitle">מערכת ניהול דיגיטלית</p>
    <p class="home-greeting"><span class="greeting-word"><%= greeting %>,</span> <strong><%= fullName %></strong></p>

    <div class="stats-row">
      <div class="stat-pill"><span class="stat-num"><%= stats.students %></span><span class="stat-label">תלמידים פעילים</span></div>
      <div class="stat-pill"><span class="stat-num"><%= stats.classes %></span><span class="stat-label">כיתות</span></div>
      <div class="stat-pill"><span class="stat-num"><%= stats.teachers %></span><span class="stat-label">מלמדים</span></div>
      <div class="stat-pill"><span class="stat-num"><%= stats.families %></span><span class="stat-label">משפחות</span></div>
      <%# סך גבייה חודשית הועבר לדף שכר לימוד %>
    </div>

    <div class="branch-stats-row">
      <% branchStats.forEach(b => { %>
        <a href="/students?status=<%= encodeURIComponent('פעיל') %>&branch=<%= b.branch === 'לא משויך' ? '__none__' : encodeURIComponent(b.branch) %>" class="branch-pill">
          <span class="branch-pill-count"><%= b.count %></span>
          <span class="branch-pill-name"><%= b.branch %></span>
        </a>
      <% }) %>
    </div>

    <div class="nav-section-divider"></div>

    <div class="nav-grid" id="nav-grid">
      <a href="/reports" class="nav-card" style="--d:1">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <div class="nav-text">דוחות</div>
        <div class="nav-sub">ייצוא ורשימות</div>
      </a>

      <a href="/students" class="nav-card" style="--d:0">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="nav-text">תלמידים</div>
        <div class="nav-sub">רשימה, חיפוש, כרטיסים</div>
      </a>
      <a href="/classes" class="nav-card" style="--d:1">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div class="nav-text">כיתות ומחזורים</div>
        <div class="nav-sub">שיבוצים וניהול כיתות</div>
      </a>
      <a href="/teachers" class="nav-card" style="--d:2">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/><path d="M18 14l2 2 4-4" stroke-width="1.8"/></svg>
        </div>
        <div class="nav-text">מלמדים ועובדים</div>
        <div class="nav-sub">סגל הוראה וניהול</div>
      </a>
      <a href="/families" class="nav-card" style="--d:3">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><circle cx="6" cy="10" r="2.5"/><circle cx="18" cy="10" r="2.5"/></svg>
        </div>
        <div class="nav-text">משפחות</div>
        <div class="nav-sub">הורים, כתובות וקשר</div>
      </a>
      <a href="/tuition" class="nav-card" style="--d:4">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="6" y1="15" x2="8" y2="15"/><line x1="10" y1="15" x2="14" y2="15"/></svg>
        </div>
        <div class="nav-text">שכר לימוד</div>
        <div class="nav-sub">תעריפים, הנחות וחישוב</div>
      </a>
      <a href="/students/new" class="nav-card" style="--d:5">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="16" y1="11" x2="22" y2="11"/></svg>
        </div>
        <div class="nav-text">קליטת תלמיד חדש</div>
        <div class="nav-sub">הוספה מהירה</div>
      </a>

      <div class="nav-card nav-card-presence" style="--d:6">
        <span class="presence-mini-title">🟢 מחוברים כעת</span>
        <ul class="presence-list-mini" id="presence-list"><li class="presence-loading">טוען...</li></ul>
      </div>

      <a href="/suppliers" class="nav-card" style="--d:7">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <div class="nav-text">ספקים</div>
        <div class="nav-sub">פרטי קשר והזמנות</div>
      </a>

      <a href="/expenses" class="nav-card" style="--d:8">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/><line x1="12" y1="10" x2="16" y2="10"/></svg>
        </div>
        <div class="nav-text">הוצאות</div>
        <div class="nav-sub">מעקב מול ספקים</div>
      </a>

      <a href="/events" class="nav-card" style="--d:9">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><circle cx="8" cy="15" r="1" fill="currentColor"/><circle cx="12" cy="15" r="1" fill="currentColor"/><circle cx="16" cy="15" r="1" fill="currentColor"/></svg>
        </div>
        <div class="nav-text">אירועים</div>
        <div class="nav-sub">לוח שנה והרשמות</div>
      </a>

      <a href="/inventory" class="nav-card" style="--d:10">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <div class="nav-text">מלאי ותחזוקה</div>
        <div class="nav-sub">ציוד ובקשות תיקון</div>
      </a>

      <a href="/parent-comm" class="nav-card" style="--d:11">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div class="nav-text">תקשורת הורים</div>
        <div class="nav-sub">מייל קבוצתי ופניות</div>
      </a>

      <a href="/books" class="nav-card" style="--d:12">
        <div class="nav-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        </div>
        <div class="nav-text">הזמנת ספרים</div>
        <div class="nav-sub">ניהול הזמנות וחיובים</div>
      </a>
    </div>

    <p class="home-footer">© כל הזכויות שמורות לתלמוד תורה החדש</p>
  </main>

  <!-- פאנל משימות - צד ימין -->
  <aside class="side-panel side-panel-right">
    <h3>📝 המשימות שלי</h3>
    <div class="side-panel-scroll">
      <% if (myTasks.length === 0) { %>
        <p class="personal-empty">אין משימות פתוחות</p>
      <% } else { %>
        <ul class="task-list">
          <% myTasks.forEach(t => { %>
            <li class="task-item <%= t.done ? 'task-done' : '' %>">
              <form method="POST" action="/tasks/<%= t.id %>/toggle" style="display:inline">
                <button type="submit" class="task-check"><%= t.done ? '☑' : '☐' %></button>
              </form>
              <span class="task-title"><%= t.title %></span>
              <% if (t.due_date_str) { %><span class="task-due"><%= t.due_date_str %></span><% } %>
              <form method="POST" action="/tasks/<%= t.id %>?_method=DELETE" style="display:inline">
                <button type="submit" class="task-delete">✕</button>
              </form>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
    <form method="POST" action="/tasks" class="task-add-form">
      <input type="text" name="title" placeholder="משימה חדשה..." required />
      <input type="date" name="due_date" />
      <button type="submit" class="btn small">+ הוסף</button>
    </form>
  </aside>

  <!-- פאנל משימות משותפות — מתחת למשימות האישיות, צד ימין -->
  <aside class="side-panel side-panel-right" style="top:auto; bottom:90px; max-height:260px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
      <h3 style="margin:0;">📋 משותפות</h3>
      <button onclick="openAddSharedTask()" style="
        background:rgba(201,151,76,0.2); border:1px solid rgba(201,151,76,0.4);
        color:#f7f1e3; border-radius:6px; padding:2px 9px; cursor:pointer; font-size:0.78em;">+ הוסף</button>
    </div>

    <!-- טופס הוספה -->
    <div id="shared-task-form" style="display:none; margin-bottom:8px;">
      <input id="shared-task-title" type="text" placeholder="תיאור המשימה..."
        style="width:100%; padding:6px 8px; border-radius:7px; margin-bottom:5px;
               border:1px solid rgba(255,255,255,0.2); background:rgba(255,255,255,0.08);
               color:#f0e9d8; font-size:0.83em;" />
      <div style="display:flex; gap:5px;">
        <select id="shared-task-assign" style="
          flex:1; padding:5px 6px; border-radius:7px; border:1px solid rgba(255,255,255,0.2);
          background:rgba(20,35,55,0.95); color:#f0e9d8; font-size:0.8em;">
          <option value="כולם">כולם</option>
          <% if (typeof allUsers !== 'undefined') allUsers.forEach(u => { %>
            <option value="<%= u.display_name || u.username %>"><%= u.display_name || u.username %></option>
          <% }) %>
        </select>
        <button onclick="submitSharedTask()" style="
          background:#2c5f7c; color:#fff; border:none; border-radius:7px;
          padding:5px 10px; cursor:pointer; font-size:0.8em;">שמור</button>
        <button onclick="closeAddSharedTask()" style="
          background:rgba(255,255,255,0.1); color:#aaa; border:none; border-radius:7px;
          padding:5px 8px; cursor:pointer; font-size:0.8em;">✕</button>
      </div>
    </div>

    <!-- רשימת משימות משותפות -->
    <div id="shared-tasks-list" class="side-panel-scroll" style="flex:1;">
      <span style="color:#7c8a96; font-size:0.82em;">טוען...</span>
    </div>
  </aside>

  <!-- פאנל הודעות - צד שמאל, תמיד מוצג -->
  <aside class="side-panel side-panel-left">
    <h3>💬 הודעות<% if (unreadCount > 0) { %> <span class="unread-badge" id="unread-count-badge"><%= unreadCount %></span><% } %></h3>
    <div class="side-panel-scroll" id="messages-preview">
      <p class="personal-empty">טוען...</p>
    </div>
    <a href="/messages" class="btn small secondary" style="width:100%; text-align:center; margin-top:8px;">כל ההודעות</a>
  </aside>

  <div class="info-bar" id="info-bar">
    <div class="info-item" id="info-clock">
      <span class="info-value" id="clock-time">--:--:--</span>
      <span class="info-label" id="clock-date"><%= dayName %>, <%= hebrewDateToday %></span>
    </div>
    <div class="info-item" id="info-parasha">
      <span class="info-value" id="parasha-value">טוען...</span>
      <span class="info-label">פרשת השבוע</span>
    </div>
    <div class="info-item" id="info-fast" style="display:none; border-color:rgba(220,80,80,0.5); background:rgba(220,80,80,0.08);">
      <span class="info-value" id="fast-value" style="color:#e07070;">—</span>
      <span class="info-label" style="color:#e07070;">⚠️ צום היום</span>
    </div>
    <div class="info-item" id="info-dafyomi">
      <span class="info-value">דף יומי</span>
      <span class="info-label" id="dafyomi-value">טוען...</span>
    </div>
    <div class="info-item" id="info-weather">
      <span class="info-value" id="weather-temp">--°</span>
      <span class="info-label">בני ברק</span>
    </div>
    <div class="info-item" id="info-shabbat">
      <span class="info-value">כניסת שבת</span>
      <span class="info-label" id="shabbat-in">טוען...</span>
    </div>
    <div class="info-item" id="info-shabbat-out">
      <span class="info-value">צאת שבת</span>
      <span class="info-label" id="shabbat-out">טוען...</span>
    </div>
    <button type="button" class="zmanim-toggle" id="zmanim-toggle" onclick="document.getElementById('zmanim-row').classList.toggle('open'); this.classList.toggle('open');">
      זמני היום ⌃
    </button>
  </div>

  <div class="zmanim-row" id="zmanim-row">
    <div class="zman-item"><span class="zman-label">עלות השחר</span><span class="zman-value" id="z-alotHaShachar">--:--</span></div>
    <div class="zman-item"><span class="zman-label">הנץ החמה</span><span class="zman-value" id="z-sunrise">--:--</span></div>
    <div class="zman-item"><span class="zman-label">סוף זמן ק"ש (מג"א)</span><span class="zman-value" id="z-sofZmanShmaMGA">--:--</span></div>
    <div class="zman-item"><span class="zman-label">סוף זמן ק"ש (גר"א)</span><span class="zman-value" id="z-sofZmanShma">--:--</span></div>
    <div class="zman-item"><span class="zman-label">סוף זמן תפילה (מג"א)</span><span class="zman-value" id="z-sofZmanTfillaMGA">--:--</span></div>
    <div class="zman-item"><span class="zman-label">סוף זמן תפילה (גר"א)</span><span class="zman-value" id="z-sofZmanTfilla">--:--</span></div>
    <div class="zman-item"><span class="zman-label">חצות היום</span><span class="zman-value" id="z-chatzot">--:--</span></div>
    <div class="zman-item"><span class="zman-label">מנחה גדולה</span><span class="zman-value" id="z-minchaGedola">--:--</span></div>
    <div class="zman-item"><span class="zman-label">מנחה קטנה</span><span class="zman-value" id="z-minchaKetana">--:--</span></div>
    <div class="zman-item"><span class="zman-label">פלג המנחה</span><span class="zman-value" id="z-plagHaMincha">--:--</span></div>
    <div class="zman-item"><span class="zman-label">שקיעה</span><span class="zman-value" id="z-sunset">--:--</span></div>
    <div class="zman-item"><span class="zman-label">צאת הכוכבים</span><span class="zman-value" id="z-tzeit7083deg">--:--</span></div>
    <div class="zman-item"><span class="zman-label">חצות הלילה</span><span class="zman-value" id="z-chatzotNight">--:--</span></div>
  </div>

  <script src="/js/info-bar.js"></script>
  <script src="/js/presence.js"></script>
  <script src="/js/messages-preview.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/shared-tasks.js"></script>
  <script>
  // ===== גרירת כרטיסי ניווט =====
  (function() {
    const grid = document.getElementById('nav-grid');
    if (!grid) return;

    // טעינת סדר שמור
    const saved = localStorage.getItem('nav-order');
    if (saved) {
      try {
        const order = JSON.parse(saved);
        const cards = [...grid.children];
        const presence = cards.find(c => c.classList.contains('nav-card-presence'));
        order.forEach(href => {
          const card = cards.find(c => c.getAttribute('href') === href);
          if (card) grid.appendChild(card);
        });
        if (presence) grid.appendChild(presence);
      } catch(e) {}
    }

    let dragSrc = null;

    grid.querySelectorAll('.nav-card:not(.nav-card-presence)').forEach(card => {
      card.setAttribute('draggable', 'true');
      card.style.cursor = 'grab';

      card.addEventListener('dragstart', e => {
        dragSrc = card;
        e.dataTransfer.effectAllowed = 'move';
        setTimeout(() => card.classList.add('dragging'), 0);
      });
      card.addEventListener('dragend', () => {
        card.classList.remove('dragging');
        grid.querySelectorAll('.nav-card').forEach(c => c.classList.remove('drag-over'));
        // שמירת הסדר
        const order = [...grid.querySelectorAll('.nav-card[href]')].map(c => c.getAttribute('href'));
        localStorage.setItem('nav-order', JSON.stringify(order));
      });
      card.addEventListener('dragover', e => {
        e.preventDefault();
        if (card !== dragSrc && !card.classList.contains('nav-card-presence')) {
          grid.querySelectorAll('.nav-card').forEach(c => c.classList.remove('drag-over'));
          card.classList.add('drag-over');
        }
      });
      card.addEventListener('drop', e => {
        e.preventDefault();
        if (dragSrc && dragSrc !== card && !card.classList.contains('nav-card-presence')) {
          const allCards = [...grid.children];
          const srcIdx = allCards.indexOf(dragSrc);
          const tgtIdx = allCards.indexOf(card);
          if (srcIdx < tgtIdx) grid.insertBefore(dragSrc, card.nextSibling);
          else grid.insertBefore(dragSrc, card);
        }
      });
    });
  })();
  </script>
</body>
</html>
